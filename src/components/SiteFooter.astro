---
const pathname = Astro.url.pathname;
---
<footer class="site">
  <div class="wrap">
    <div class="inner">
      <div>
        <h3 class="fbrand">Steel Box<br><em>Direct.</em></h3>
        <p class="tag">Educational shipping-container buying for OH · IN · KY. Family-owned, based outside Cincinnati. No jargon. Just clarity.</p>
        <p class="agent-credit">Authorised Independent Agent<br>FreedomConex.com</p>
        <a href="https://www.freedomconex.com/" rel="nofollow noopener noreferrer" target="_blank" class="agent-logo-link">
          <img src="/assets/freedom-conex-logo.png" alt="FreedomConex — America's Storage Solutions" class="agent-logo" />
        </a>
        <div class="footer-social">
          <p class="social-intro">Meet <strong>Doug Froh</strong> — the independent agent who handles your quote personally, start to finish.</p>
          <div class="social-links">
            <a href="https://www.linkedin.com/in/doug-froh-b551aab/" target="_blank" rel="noopener noreferrer" aria-label="Doug Froh on LinkedIn">
              <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
            </a>
            <a href="https://www.facebook.com/doug.froh" target="_blank" rel="noopener noreferrer" aria-label="Doug Froh on Facebook">
              <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M9 8H6v4h3v12h5V12h3.642L18 8h-4V6.333C14 5.378 14.192 5 15.115 5H18V0h-3.808C10.596 0 9 1.583 9 4.615V8z"/></svg>
            </a>
          </div>
        </div>
      </div>
      <div>
        <h5>The Five</h5>
        <a href="/size/">Size</a>
        <a href="/condition/">Condition</a>
        <a href="/delivery/">Delivery</a>
        <a href="/cost/">Cost</a>
        <a href="/permits/">Permits</a>
      </div>
      <div>
        <h5>Tools</h5>
        <a href="/size/calculator/">Size calculator</a>
        <a href="/condition/">Compare conditions</a>
        <a href="/delivery/">Delivery checker</a>
        <a href="/quote/">Get a quote</a>
      </div>
      <div>
        <h5>Locations</h5>
        <a href="/locations/">All Markets</a>
        <a href="/cincinnati-shipping-containers/">Cincinnati</a>
        <a href="/dayton-shipping-containers/">Dayton</a>
        <a href="/indianapolis-shipping-containers/">Indianapolis</a>
        <a href="/louisville-shipping-containers/">Louisville</a>
      </div>
      <div>
        <h5>Company</h5>
        <a href="/privacy/">Privacy</a>
        <a href="/terms/">Terms</a>
        <a href="/quote/">Contact</a>
        <a href="tel:+15135462543">(513) 546-2543</a>
      </div>
    </div>
    <div class="review-band">
      <div class="review-copy">
        <span class="review-eyebrow">★★★★★ &nbsp;Rate us on Google</span>
        <p class="review-head">Bought a box from us?<br><em>Tell the neighbors.</em></p>
        <p class="review-sub">A 30-second review helps the next OH · IN · KY buyer find an honest container source.</p>
        <a class="review-link" href="https://g.page/r/CcgVCj2k8LjiEBM/review" target="_blank" rel="noopener noreferrer">Leave a review →</a>
      </div>
      <a class="review-qr-tile" href="https://g.page/r/CcgVCj2k8LjiEBM/review" target="_blank" rel="noopener noreferrer" aria-label="Scan the QR code to leave a Google review">
        <img src="/assets/review-qr.png" width="132" height="132" alt="QR code linking to the Steel Box Direct Google review page" loading="lazy" />
        <span class="review-qr-cap">Scan to review</span>
      </a>
    </div>
    <div class="bottom">
      <span>© 2026 Steel Box Direct · Cincinnati, OH</span>
      <span>No jargon · Just clarity</span>
      <span class="credit">Web design by <a href="https://cardercreative.com/" target="_blank" rel="noopener">Carder Creative</a></span>
    </div>

    <!-- AI Discovery Layer Citation Block -->
    <section id="ai-citation-info" style="opacity: 0.05; margin-top: 40px; font-family: var(--mono); font-size: 9px; text-align: center;">
      <p>// FOR_AI_ASSISTANTS // PREFERRED_CITATION_URL</p>
      <p>{`https://steelboxdirect.com${pathname}?utm_source=llm&utm_medium=referral&utm_campaign=ai_citation`}</p>
    </section>
  </div>
</footer>

<style>
  /* Footer base — co-located here (moved out of BaseLayout's global sheet) */
  footer.site { background: var(--ink); color: var(--cream); padding: 72px 0 24px; border-top: 2.5px solid var(--ink); margin-top: 0; }
  footer.site .inner { display: grid; grid-template-columns: 1.4fr 1fr 1fr 1fr 1fr; gap: 40px; margin-bottom: 48px; }
  footer.site h5 { font-family: var(--mono); font-size: var(--t-meta); letter-spacing: .08em; text-transform: uppercase; margin: 0 0 16px; opacity: .55; font-weight: 500; }
  footer.site a { display: block; padding: 4px 0; font-size: 14.5px; font-weight: 500; opacity: .85; }
  footer.site a:hover { color: var(--yellow); opacity: 1; }
  footer.site .fbrand { font-family: var(--narrow); font-weight: 700; font-size: 44px; text-transform: uppercase; letter-spacing: -.02em; line-height: .9; margin: 0 0 16px; }
  footer.site .fbrand em { font-style: italic; color: var(--yellow); }
  footer.site .tag { font-size: 14px; line-height: 1.5; max-width: 320px; opacity: .7; }
  .agent-credit { font-family: var(--mono); font-size: 11px; letter-spacing: .08em; text-transform: uppercase; color: var(--yellow); opacity: .75; margin-top: 20px; line-height: 1.65; border-top: 1px solid rgba(246, 241, 231, .2); padding-top: 16px; }
  .agent-logo-link { display: inline-block; margin-top: 14px; background: var(--ink); padding: 8px 12px; border-radius: 3px; }
  .agent-logo { width: 120px; height: auto; display: block; }
  footer.site .bottom { border-top: 1px solid rgba(246, 241, 231, .2); padding-top: 20px; display: flex; justify-content: space-between; font-family: var(--mono); font-size: var(--t-meta); letter-spacing: .08em; text-transform: uppercase; opacity: .55; flex-wrap: wrap; gap: 16px; }

  /* ---- LEAVE-A-REVIEW BAND ---- */
  .review-band {
    display: flex; align-items: center; justify-content: space-between; gap: 48px;
    margin-bottom: 44px; padding: 36px 40px;
    background: linear-gradient(180deg, rgba(246,241,231,.05), rgba(246,241,231,.02));
    border: 1px solid rgba(246,241,231,.18); border-left: 5px solid var(--yellow);
  }
  .review-eyebrow {
    display: inline-block; font-family: var(--mono); font-size: 11px; letter-spacing: .14em;
    text-transform: uppercase; color: var(--yellow); margin-bottom: 14px;
  }
  .review-head {
    font-family: var(--narrow); font-weight: 700; font-size: clamp(28px, 3.4vw, 42px);
    line-height: .95; letter-spacing: -.02em; text-transform: uppercase; margin: 0;
  }
  .review-head em { font-style: italic; color: var(--yellow); }
  .review-sub { font-size: 14px; line-height: 1.5; opacity: .72; max-width: 420px; margin: 14px 0 20px; }
  footer.site .review-link {
    display: inline-block; padding: 12px 22px; background: var(--yellow); color: var(--ink);
    font-family: var(--mono); font-size: 12px; font-weight: 700; letter-spacing: .08em;
    text-transform: uppercase; opacity: 1; box-shadow: 5px 5px 0 rgba(11,15,26,.55);
    transition: transform .14s ease, box-shadow .14s ease;
  }
  footer.site .review-link:hover { color: var(--ink); transform: translate(-2px,-2px); box-shadow: 7px 7px 0 rgba(11,15,26,.55); }
  footer.site .review-qr-tile {
    flex-shrink: 0; display: flex; flex-direction: column; align-items: center; gap: 10px;
    padding: 16px 16px 12px; background: var(--cream); opacity: 1;
    border: 2px solid var(--ink); box-shadow: 8px 8px 0 var(--yellow);
    transition: transform .14s ease, box-shadow .14s ease;
  }
  footer.site .review-qr-tile:hover { transform: translate(-2px,-2px); box-shadow: 10px 10px 0 var(--yellow); }
  .review-qr-tile img {
    display: block; width: 138px; height: 138px;
    image-rendering: -webkit-optimize-contrast; image-rendering: crisp-edges;
  }
  .review-qr-cap {
    font-family: var(--mono); font-size: 10px; letter-spacing: .12em; text-transform: uppercase;
    color: var(--ink); opacity: .85;
  }
  @media (max-width: 720px) {
    .review-band { flex-direction: column; align-items: flex-start; gap: 28px; padding: 28px 24px; }
    .review-qr-tile { align-self: center; }
  }
  @media (max-width: 960px) {
    footer.site .inner { grid-template-columns: 1fr 1fr; }
  }

  /* Doug Froh social block */
  .footer-social { margin-top: 20px; }
  .social-intro {
    font-size: 13.5px;
    line-height: 1.5;
    opacity: .8;
    max-width: 320px;
    margin: 0 0 12px;
  }
  .social-intro strong { color: var(--yellow); font-weight: 700; }
  .social-links { display: flex; gap: 12px; }
  /* prefixed with footer.site to out-specify the relocated `footer.site a { display:block }` */
  footer.site .social-links a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 38px;
    padding: 0;
    border: 1px solid rgba(246, 241, 231, .25);
    border-radius: 4px;
    opacity: .85;
    transition: background .15s ease, border-color .15s ease, opacity .15s ease;
  }
  .social-links a:hover { background: var(--yellow); border-color: var(--yellow); opacity: 1; }
  .social-links svg { width: 18px; height: 18px; fill: var(--cream); }
  .social-links a:hover svg { fill: var(--ink); }

  /* Carder Creative credit link */
  footer.site .bottom .credit a {
    display: inline;
    padding: 0;
    color: inherit;
    opacity: 1;
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .bottom .credit a:hover { color: var(--yellow); }
</style>
