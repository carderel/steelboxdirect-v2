<!-- ============ §08 CTA ============ -->
<section class="cta" id="cta">
  <div class="inner cta_inner">
    <h2 class="big">Ready? <em>Let's talk.</em></h2>
    <p>A quote is just information. Tell us what you're protecting — we'll send a real number and a delivery window. Usually same day.</p>
    <a class="btn" href="/quote/">Get my quote <svg viewBox="0 0 24 24"><path d="M5 12h14M13 5l7 7-7 7"/></svg></a>
    <div class="reassure cta_reassure">
      <span>No obligation</span>
      <span>Real human replies</span>
      <span>All-in pricing, always</span>
    </div>
    <p style="margin-top:2rem;font-family:var(--mono);font-size:11px;letter-spacing:.06em;text-transform:uppercase;opacity:.6">Serving <a href="/cincinnati-shipping-containers/" style="color:inherit;border-bottom:1px solid currentColor">Cincinnati</a> · <a href="/dayton-shipping-containers/" style="color:inherit;border-bottom:1px solid currentColor">Dayton</a> · <a href="/indianapolis-shipping-containers/" style="color:inherit;border-bottom:1px solid currentColor">Indianapolis</a> · <a href="/louisville-shipping-containers/" style="color:inherit;border-bottom:1px solid currentColor">Louisville</a> and surrounding areas — <a href="/locations/" style="color:inherit;border-bottom:1px solid currentColor">see full delivery map</a></p>
  </div>
</section>

<style>
  /* CTA */
  .cta{background:var(--yellow);color:var(--ink);padding:2.5em 0;border-bottom:2.5px solid var(--ink);position:relative;overflow:hidden}
  .cta .inner{max-width:1200px;margin:0 auto;padding:0 32px;text-align:center;position:relative;z-index:1}
  .cta .big{font-family:var(--narrow);font-weight:700;font-size:clamp(60px,11vw,180px);line-height:.84;letter-spacing:-.02em;text-transform:uppercase;margin:0 0 32px}
  .cta .big em{color:var(--c2-cond)}
  .cta p{font-size:22px;line-height:1.4;max-width:640px;margin:0 auto 40px;font-weight:500}
  .cta .btn{display:inline-flex;align-items:center;gap:10px;padding:22px 32px;background:var(--ink);color:var(--yellow);font-family:var(--narrow);font-weight:700;font-size:18px;text-transform:uppercase;letter-spacing:.02em;border:2.5px solid var(--ink);transition:background .15s,color .15s;cursor:pointer}
  .cta .btn:hover{background:var(--yellow);color:var(--ink)}
  .cta .btn svg{width:18px;height:18px;stroke:currentColor;stroke-width:2.6;fill:none}
  .cta .reassure{margin-top:40px;display:flex;gap:36px;justify-content:center;flex-wrap:wrap;font-family:var(--mono);font-size:11px;letter-spacing:.08em;text-transform:uppercase;opacity:.65}
  .cta .reassure span::before{content:"●";margin-right:8px;color:var(--c4-cost)}

  @media (max-width:720px){
    .cta .big{font-size:clamp(44px,12vw,80px)}
  }
</style>
