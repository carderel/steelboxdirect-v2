---
<!-- ============ §06 PRICING TEASER ============ -->
<section class="price" id="price">
  <div class="wrap pricing_wrap">
    <div class="sh">
      <span class="idx">§ 04</span>
      <span class="nm">What it really costs</span>
      <span class="tg">All-in · no hidden fees</span>
    </div>
    <h2 class="big">Three price points.<br><em>One honest number</em> each.</h2>
    <p class="intro">These are recent averages — container, delivery, and placement on flat ground included. Container prices fluctuate with market availability. <a href="/quote/" style="color:inherit;border-bottom:1.5px solid currentColor">Submit a quote</a> for current pricing.</p>

    <div class="pgrid pricing_grid">
      <div class="pcard pricing_card">
        <div class="tag pricing_name"><span class="name">20-ft cargo</span><span class="chip">Most available</span></div>
        <ul class="pricing_features">
          <li>~160 sq ft · fits a tractor or a lot of tools</li>
          <li>Wind &amp; Water Tight, minor surface rust</li>
          <li>Next-week delivery usually available</li>
        </ul>
        <a href="/shipping-containers-for-sale/20-foot-shipping-container/" class="pcard-cta pricing_cta">See full specs <span>→</span></a>
      </div>
      <div class="pcard rec pricing_card">
        <div class="tag pricing_name"><span class="name">40-ft cargo</span><span class="chip">Most popular</span></div>
        <ul class="pricing_features">
          <li>~320 sq ft · equipment + implements + shelving</li>
          <li>The Sweet Spot — best value per square foot</li>
          <li>Fits farms, job sites, and commercial properties</li>
        </ul>
        <a href="/shipping-containers-for-sale/40-foot-shipping-container/" class="pcard-cta pricing_cta">See full specs <span>→</span></a>
      </div>
      <div class="pcard pricing_card">
        <div class="tag pricing_name"><span class="name">40-ft one-trip</span><span class="chip">New</span></div>
        <ul class="pricing_features">
          <li>Single trip from factory · factory finish</li>
          <li>25-year weather protection, warranty-backed</li>
          <li>Best choice for conversions and builds</li>
        </ul>
        <a href="/shipping-containers-for-sale/40-foot-one-trip-container/" class="pcard-cta pricing_cta">See full specs <span>→</span></a>
      </div>
    </div>
    <p style="font-family:var(--mono);font-size:13px;letter-spacing:.04em;font-weight:500;opacity:.7;text-transform:uppercase;margin-top:2rem;line-height:1.75">
      Container pricing tracks global shipping rates and steel supply — it shifts week to week. We don't post numbers that will be wrong by the time you read them. Request a quote for the current price that applies to your order.
    </p>
  </div>
</section>

<style>
  /* Sections Shared */
  .sh{display:grid;grid-template-columns:auto 1fr auto;gap:20px;align-items:center;padding:18px 0;border-top:2px solid var(--ink);border-bottom:2px solid var(--ink);margin-bottom:72px}
  .sh .idx{font-family:var(--mono);font-size:var(--t-meta);letter-spacing:.08em;text-transform:uppercase}
  .sh .nm{font-family:var(--narrow);font-weight:700;font-size:22px;text-transform:uppercase;letter-spacing:-.01em}
  .sh .tg{font-family:var(--mono);font-size:var(--t-meta);letter-spacing:.08em;text-transform:uppercase;opacity:.55;text-align:right}
  .big{font-family:var(--narrow);font-weight:700;font-size:var(--t-big);line-height:.9;letter-spacing:-.02em;text-transform:uppercase;margin:0}
  .big em{font-style:italic;color:var(--c5-permits);font-weight:700}

  /* Price */
  .price{background:var(--ink);color:var(--cream);padding:120px 0;border-bottom:2.5px solid var(--ink)}
  .price .sh{border-color:var(--cream);color:var(--cream)}
  .price .big{color:var(--cream)}
  .price .big em{color:var(--c1-size)}
  .price .intro{font-size:var(--t-lede);line-height:1.5;margin:2em 0 56px;max-width:640px;opacity:.85}
  .pgrid{display:grid;grid-template-columns:repeat(3,1fr);gap:0;border:2.5px solid var(--cream)}
  .pcard{padding:32px 28px;border-right:2.5px solid var(--cream);display:flex;flex-direction:column;gap:16px;background:var(--ink);transition:background .15s}
  .pcard:last-child{border-right:none}
  .pcard:hover{background:var(--ink-2)}
  .pcard .tag{display:flex;justify-content:space-between;align-items:center}
  .pcard .tag .name{font-family:var(--narrow);font-weight:700;font-size:22px;text-transform:uppercase;letter-spacing:-.01em}
  .pcard .tag .chip{font-family:var(--mono);font-size:10px;letter-spacing:.08em;text-transform:uppercase;padding:3px 8px;background:var(--c1-size);color:var(--ink)}
  .pcard.rec .tag .chip{background:var(--c5-permits);color:var(--cream)}
  .pcard .num{font-family:var(--narrow);font-weight:700;font-size:80px;line-height:.85;letter-spacing:-.03em}
  .pcard .num small{font-family:var(--mono);font-size:13px;letter-spacing:.04em;font-weight:500;opacity:.7;display:block;margin-top:1em;text-transform:uppercase}
  .pcard ul{list-style:none;padding:0;margin:0;font-size:14.5px;line-height:1.55}
  .pcard ul li{padding:8px 0;border-bottom:1px solid rgba(246,241,231,.2);display:flex;align-items:flex-start;gap:10px}
  .pcard ul li:last-child{border-bottom:none}
  .pcard ul li::before{content:"→";color:var(--c1-size);flex-shrink:0;font-family:var(--mono);font-weight:700}
  .pcard.rec{background:var(--ink-2);outline:2.5px solid var(--c5-permits);outline-offset:-2.5px;position:relative}
  .pcard-cta{margin-top:auto;display:flex;justify-content:space-between;align-items:center;padding:12px 16px;background:var(--cream);color:var(--ink);font-family:var(--mono);font-size:11px;font-weight:700;letter-spacing:.06em;text-transform:uppercase;text-decoration:none;transition:background .15s,color .15s}
  .pcard-cta:hover{background:var(--yellow)}
  .pcard.rec .pcard-cta{background:var(--c5-permits);color:var(--cream)}
  .pcard.rec .pcard-cta:hover{background:var(--yellow);color:var(--ink)}

  @media (max-width:960px){
    .pgrid{grid-template-columns:1fr}
    .pcard{border-right:none;border-bottom:2.5px solid var(--cream)}
    .pcard:last-child{border-bottom:none}
  }

  @media (max-width:720px){
    .big{font-size:clamp(36px,9vw,64px)}
    .sh{grid-template-columns:auto 1fr;row-gap:6px}
    .sh .tg{grid-column:1 / -1;text-align:left;opacity:.5}
  }
</style>
