---
import Schema from '../components/Schema.astro';
import SiteNav from '../components/SiteNav.astro';
import SiteFooter from '../components/SiteFooter.astro';
import FloatingSidebar from '../components/FloatingSidebar.astro';

interface CityOverride {
  name: string;
  addressRegion: string;
  latitude: string;
  longitude: string;
}

interface Props {
  title: string;
  description?: string;
  pageType?: 'home' | 'guide' | 'tool' | 'quote' | 'legal' | 'product';
  guideTopic?: 'size' | 'condition' | 'delivery' | 'cost' | 'permits';
  cityOverride?: CityOverride;
  noindex?: boolean;
  datePublished?: string;
  dateModified?: string;
}

const {
  title,
  description = 'Make informed decisions about shipping containers. Size guides, condition comparisons, delivery requirements, and expert guidance.',
  pageType = 'home',
  guideTopic,
  cityOverride,
  noindex = false,
  datePublished,
  dateModified,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <!-- Google Tag Manager -->
    <script is:inline>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
    new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
    j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
    'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
    })(window,document,'script','dataLayer','GTM-K4T6CHW8');</script>
    <!-- End Google Tag Manager -->
    <!-- ⚠️ GOOGLE SEARCH CONSOLE VERIFICATION — DO NOT REMOVE OR MODIFY.
         Removing this tag will immediately break GSC ownership and disconnect all indexing data. -->
    <meta name="google-site-verification" content="KmX6Bb2bFi1wX2mLyvVaXZAI0bddzz0Amh4lLq73vsA" />
    <!-- END GSC VERIFICATION -->
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <meta property="og:type" content="website" />
    <meta property="og:url" content={`https://steelboxdirect.com${Astro.url.pathname}`} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content="Steel Box Direct" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <link rel="canonical" href={`https://steelboxdirect.com${Astro.url.pathname}`} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="preload" as="style" onload="this.onload=null;this.rel='stylesheet'" href="https://fonts.googleapis.com/css2?family=Archivo+Narrow:wght@500;600;700&family=Archivo:wght@400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500&family=Permanent+Marker&display=swap" />
    <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Archivo+Narrow:wght@500;600;700&family=Archivo:wght@400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500&family=Permanent+Marker&display=swap" /></noscript>

    <!-- Schema Markup -->
    <Schema pageType={pageType} pageTitle={title} pageDescription={description} guideTopic={guideTopic} cityOverride={cityOverride} datePublished={datePublished} dateModified={dateModified} />
    <slot name="head" />

    <!-- Attribution tracking initialization -->
    <script>
      import { initAttribution } from '../lib/attribution';
      initAttribution();
    </script>
  </head>
  <body>
    <!-- Google Tag Manager (noscript) -->
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-K4T6CHW8"
    height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
    <!-- End Google Tag Manager (noscript) -->
    <SiteNav />

    <main class={pageType === 'home' ? 'home-main' : ''}>
      <slot />
    </main>

    <SiteFooter />

    {pageType === 'home' && <FloatingSidebar />}

    <style is:global>
      :root{
        /* Anchor */
        --yellow:  #FFD300;       /* saturated traffic-sign yellow */
        --yellow-d:#E8BC00;
        --cream:   #F6F1E7;
        --ink:     #0B0F1A;
        --ink-2:   #1A2030;

        /* Sim Sim decision-block palette — each a different saturated primary */
        --c1-size:     #FFD300;   /* yellow */
        --c2-cond:     #E53935;   /* red */
        --c3-deliver:  #1747E6;   /* cobalt */
        --c4-cost:     #0B8F4E;   /* kelly green */
        --c5-permits:  #FF5A1F;   /* signal orange */

        --display: 'Archivo', system-ui, sans-serif;
        --narrow:  'Archivo Narrow', 'Archivo', system-ui, sans-serif;
        --mono:    'JetBrains Mono', ui-monospace, monospace;

        --max: 1320px;

        /* Type scale — loud */
        --t-billboard: clamp(44px, 10vw, 168px);  /* reduced ~30% per user request */
        --t-mega:      clamp(72px, 11vw, 180px);
        --t-big:       clamp(44px, 6.5vw, 88px);
        --t-card:      clamp(26px, 2.8vw, 40px);
        --t-lede:      19px;
        --t-body:      16px;
        --t-meta:      11px;
      }

      *{box-sizing:border-box}
      html,body{margin:0;padding:0;background:var(--cream);color:var(--ink);font-family:var(--display);-webkit-font-smoothing:antialiased}
      a{color:inherit;text-decoration:none}
      img{max-width:100%;display:block}
      .wrap{max-width:var(--max);margin:0 auto;padding:0 32px}

      /* ---- Repeated utility labels ---- */
      .m{font-family:var(--mono);font-size:var(--t-meta);letter-spacing:.08em;text-transform:uppercase}
      .m-dot::before{content:"●";margin-right:8px;color:var(--ink)}

      /* ============ HEADER ============ */
      header.site{position:sticky;top:0;z-index:100;background:var(--yellow);border-bottom:2px solid var(--yellow-d)}
      .nav{display:flex;align-items:stretch;justify-content:space-between;min-height:60px;background:var(--yellow);border-bottom:2.5px solid var(--ink)}
      .brand-group{display:flex;flex-direction:column;justify-content:center;gap:4px;padding:10px 0}
      .brand{display:flex;align-items:center;gap:10px;font-family:var(--narrow);font-weight:700;font-size:22px;letter-spacing:-.02em;text-transform:uppercase}
      .brand .bx{width:30px;height:30px;background:var(--ink);color:var(--yellow);display:grid;place-items:center;font-weight:900;font-size:15px;font-family:var(--display)}
      .brand-mil{font-family:var(--mono);font-size:10px;letter-spacing:.06em;text-transform:uppercase;color:#3a2f00;line-height:1.2;margin-top:8px}

      .menu-toggle {
        display: none;
        align-items: center;
        gap: 8px;
        background: var(--ink);
        color: var(--yellow);
        border: none;
        padding: 6px 12px;
        font-family: var(--mono);
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        cursor: pointer;
        width: fit-content;
      }
      .menu-toggle svg {
        width: 18px;
        height: 18px;
        stroke: currentColor;
        stroke-width: 2.8;
        fill: none;
      }

      nav.p{display:flex;align-items:center;gap:0}
      nav.p a{font-family:var(--mono);font-size:1.1em;letter-spacing:.06em;text-transform:uppercase;padding:10px 18px;border-right:1.5px solid var(--ink)}
      nav.p > a:first-child{border-left:1.5px solid var(--ink)}
      nav.p a:hover{background:var(--ink);color:var(--yellow)}

      /* Nav location dropdown */
      .nav-loc{position:relative;display:flex;align-items:stretch}
      .nav-loc-trigger{display:inline-flex;align-items:center;gap:6px;white-space:nowrap}
      .nav-loc-trigger svg{width:10px;height:10px;stroke:currentColor;stroke-width:2.8;fill:none;transition:transform .2s;flex-shrink:0}
      .nav-loc:hover .nav-loc-trigger{background:var(--ink);color:var(--yellow)}
      .nav-loc:hover .nav-loc-trigger svg{transform:rotate(180deg)}
      .nav-loc-drop{position:absolute;top:100%;left:0;min-width:210px;background:var(--ink);border:2.5px solid var(--ink);display:none;z-index:200}
      .nav-loc:hover .nav-loc-drop{display:block}
      .nav-loc-drop a{display:flex;align-items:center;gap:14px;padding:13px 18px;border-bottom:1px solid rgba(246,241,231,.1);color:var(--cream);font-family:var(--mono);font-size:11px;letter-spacing:.06em;text-transform:uppercase;border-right:none!important}
      .nav-loc-drop a:last-child{border-bottom:none}
      .nav-loc-drop a:hover{background:var(--yellow);color:var(--ink)}
      .dc{font-family:var(--narrow);font-weight:700;font-size:22px;line-height:1;letter-spacing:-.01em;flex-shrink:0}
      .nav-loc-drop a .dc{color:var(--yellow)}
      .nav-loc-drop a:hover .dc{color:var(--cream)}

      /* Nav containers dropdown */
      .nav-con{position:relative;display:flex;align-items:stretch}
      .nav-con-trigger{display:inline-flex;align-items:center;gap:6px;white-space:nowrap}
      .nav-con-trigger svg{width:10px;height:10px;stroke:currentColor;stroke-width:2.8;fill:none;transition:transform .2s;flex-shrink:0}
      .nav-con:hover .nav-con-trigger{background:var(--ink);color:var(--yellow)}
      .nav-con:hover .nav-con-trigger svg{transform:rotate(180deg)}
      .nav-con-drop{position:absolute;top:100%;left:0;min-width:210px;background:var(--ink);border:2.5px solid var(--ink);display:none;z-index:200}
      .nav-con:hover .nav-con-drop{display:block}
      .nav-con-drop a{display:flex;align-items:center;gap:14px;padding:13px 18px;border-bottom:1px solid rgba(246,241,231,.1);color:var(--cream);font-family:var(--mono);font-size:11px;letter-spacing:.06em;text-transform:uppercase;border-right:none!important}
      .nav-con-drop a:last-child{border-bottom:none}
      .nav-con-drop a:hover{background:var(--yellow);color:var(--ink)}
      .nav-con-drop a .dc{color:var(--yellow)}
      .nav-con-drop a:hover .dc{color:var(--cream)}

      /* Nav guides dropdown */
      .nav-gd{position:relative;display:flex;align-items:stretch}
      .nav-gd-trigger{display:inline-flex;align-items:center;gap:6px;white-space:nowrap}
      .nav-gd-trigger svg{width:10px;height:10px;stroke:currentColor;stroke-width:2.8;fill:none;transition:transform .2s;flex-shrink:0}
      .nav-gd:hover .nav-gd-trigger{background:var(--ink);color:var(--yellow)}
      .nav-gd:hover .nav-gd-trigger svg{transform:rotate(180deg)}
      .nav-gd-drop{position:absolute;top:100%;left:0;min-width:210px;background:var(--ink);border:2.5px solid var(--ink);display:none;z-index:200}
      .nav-gd:hover .nav-gd-drop{display:block}
      .nav-gd-drop a{display:flex;align-items:center;gap:14px;padding:13px 18px;border-bottom:1px solid rgba(246,241,231,.1);color:var(--cream);font-family:var(--mono);font-size:11px;letter-spacing:.06em;text-transform:uppercase;border-right:none!important}
      .nav-gd-drop a:last-child{border-bottom:none}
      .nav-gd-drop a:hover{background:var(--yellow);color:var(--ink)}
      .nav-gd-drop a .dc{color:var(--yellow)}
      .nav-gd-drop a:hover .dc{color:var(--cream)}

      /* Nav tools dropdown */
      .nav-tl{position:relative;display:flex;align-items:stretch}
      .nav-tl-trigger{display:inline-flex;align-items:center;gap:6px;white-space:nowrap}
      .nav-tl-trigger svg{width:10px;height:10px;stroke:currentColor;stroke-width:2.8;fill:none;transition:transform .2s;flex-shrink:0}
      .nav-tl:hover .nav-tl-trigger{background:var(--ink);color:var(--yellow)}
      .nav-tl:hover .nav-tl-trigger svg{transform:rotate(180deg)}
      .nav-tl-drop{position:absolute;top:100%;left:0;min-width:210px;background:var(--ink);border:2.5px solid var(--ink);display:none;z-index:200}
      .nav-tl:hover .nav-tl-drop{display:block}
      .nav-tl-drop a{display:flex;align-items:center;gap:14px;padding:13px 18px;border-bottom:1px solid rgba(246,241,231,.1);color:var(--cream);font-family:var(--mono);font-size:11px;letter-spacing:.06em;text-transform:uppercase;border-right:none!important}
      .nav-tl-drop a:last-child{border-bottom:none}
      .nav-tl-drop a:hover{background:var(--yellow);color:var(--ink)}
      .nav-tl-drop a .dc{color:var(--yellow)}
      .nav-tl-drop a:hover .dc{color:var(--cream)}

      .cta-hd{display:inline-flex;align-items:center;gap:8px;padding:0 22px;background:var(--ink);color:var(--yellow);font-family:var(--narrow);font-weight:700;font-size:14px;text-transform:uppercase;letter-spacing:.02em;border-left:2.5px solid var(--ink)}
      .cta-hd:hover{background:var(--cream);color:var(--ink)}
      .cta-hd svg{width:14px;height:14px;stroke:currentColor;stroke-width:2.6;fill:none}

      /* ---- Secondary use-case strip (full-width yellow row under main nav) ---- */
      .subnav-wrap{background:var(--yellow)}
      .subnav{display:flex;justify-content:flex-end;align-items:center;gap:16px;min-height:34px}
      .subnav-links{display:flex;align-items:center;flex-wrap:wrap;gap:8px 4px}
      .subnav-label{font-family:var(--mono);font-size:12.5px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--ink);opacity:.65;margin-right:6px}
      .subnav-links a{position:relative;font-family:var(--mono);font-size:13px;letter-spacing:.08em;text-transform:uppercase;color:#8a6d00;padding:8px 14px;transition:color .12s}
      /* tasteful separators between links (not before the first link) */
      .subnav-links a + a::before{content:"";position:absolute;left:0;top:50%;transform:translateY(-50%);width:1px;height:13px;background:#8a6d00;opacity:.5}
      .subnav-links a:hover{color:var(--ink);text-decoration:underline;text-underline-offset:3px;text-decoration-thickness:1.5px}

      /* ---- Call Now button (template: .cta-hd — ink bg / yellow text) ---- */
      .call-now{display:inline-flex;align-items:center;gap:8px;padding:0 16px;background:transparent;color:var(--ink);font-family:var(--narrow);font-weight:700;font-size:13px;text-transform:uppercase;letter-spacing:.02em;white-space:nowrap}
      .call-now .call-ico{width:14px;height:14px;stroke:currentColor;stroke-width:2.2;fill:none;flex-shrink:0}
      .call-now .call-num{font-family:var(--mono);font-weight:700;font-size:12px;letter-spacing:.04em}
      /* no box, no hover fill — the revealed number keeps the same ink text as the "Call Now" label */
      /* Desktop hover-capable: show "Call Now"; reveal number on hover (snappy width morph) */
      @media (hover:hover) and (pointer:fine){
        .call-now .call-num{max-width:0;overflow:hidden;opacity:0;transition:max-width .28s ease,opacity .2s ease,margin .28s ease;margin-left:-8px}
        .call-now:hover .call-num{max-width:160px;opacity:1;margin-left:0}
        .call-now:hover .call-label{display:none}
      }
      /* Touch / no-hover: render the tappable number directly (no hover reliance) */
      @media (hover:none){
        .call-now .call-label{display:none}
        .call-now .call-num{max-width:none;opacity:1}
      }

      .agent-strip{padding:4px 0;font-family:var(--mono);font-size:9px;letter-spacing:.06em;text-transform:uppercase;color:#444}
      .agent-strip-inner{display:flex;justify-content:flex-end;align-items:center}

      /* ============ BUTTONS ============ */
      .btn{display:inline-flex;align-items:center;gap:10px;padding:18px 26px;background:var(--ink);color:var(--yellow);font-family:var(--narrow);font-weight:700;font-size:16px;text-transform:uppercase;letter-spacing:.02em;border:2.5px solid var(--ink);transition:background .15s,color .15s; cursor: pointer;}
      .btn:hover{background:var(--yellow);color:var(--ink)}
      .btn svg{width:18px;height:18px;stroke:currentColor;stroke-width:2.6;fill:none}
      .btn-ghost{display:inline-flex;align-items:center;gap:8px;font-family:var(--mono);font-size:12px;letter-spacing:.08em;text-transform:uppercase;border-bottom:1.5px solid currentColor;padding:3px 0}
      .btn-ghost:hover{color:var(--c5-permits)}

      /* Footer styles co-located in src/components/SiteFooter.astro */

      /* Main overrides */
      main.home-main {
        max-width: none;
        margin: 0;
        padding: 0;
      }

      /* ============ FLOATING DECISION SIDEBAR ============ */
      .sidebar-float{
        position:fixed;right:24px;bottom:24px;z-index:90;
        width:340px;max-width:calc(100vw - 32px);
        background:var(--cream);color:var(--ink);
        border:2.5px solid var(--ink);
        box-shadow:10px 10px 0 var(--ink);
        transform-origin:bottom right;
        transition:transform .25s ease, opacity .25s ease;
      }
      .sidebar-float.is-hidden{transform:translateY(calc(100% + 40px)) scale(.9);opacity:0;pointer-events:none}

      .sbf-hd{
        background:var(--yellow);border-bottom:2.5px solid var(--ink);
        padding:10px 14px;display:flex;align-items:center;justify-content:space-between;gap:10px;
      }
      .sbf-hd .tag{display:flex;align-items:center;gap:8px;font-family:var(--mono);font-size:10.5px;font-weight:600;letter-spacing:.1em;text-transform:uppercase}
      .sbf-hd .dot{width:8px;height:8px;border-radius:50%;background:var(--c2-cond);box-shadow:0 0 0 3px rgba(217,59,50,.18);animation:sbf-pulse 2s ease-in-out infinite}
      @keyframes sbf-pulse{0%,100%{box-shadow:0 0 0 3px rgba(217,59,50,.18)}50%{box-shadow:0 0 0 6px rgba(217,59,50,.06)}}
      .sbf-hd .close{background:transparent;border:1.5px solid var(--ink);width:22px;height:22px;display:grid;place-items:center;cursor:pointer;padding:0;font-family:var(--mono);font-size:13px;line-height:1;color:var(--ink)}
      .sbf-hd .close:hover{background:var(--ink);color:var(--yellow)}

      .sbf-primary{padding:18px 16px 14px;border-bottom:1.5px solid rgba(11,15,26,.15)}
      .sbf-primary .mini{font-family:var(--mono);font-size:10px;font-weight:600;letter-spacing:.1em;text-transform:uppercase;color:rgba(11,15,26,.6);margin-bottom:6px}
      .sbf-primary h4{font-family:var(--narrow);font-weight:700;font-size:22px;line-height:1.05;letter-spacing:-.01em;text-transform:uppercase;margin:0 0 4px}
      .sbf-primary p{font-size:13.5px;line-height:1.45;margin:0 0 12px;color:rgba(11,15,26,.72)}
      .sbf-btn{
        display:flex;align-items:center;justify-content:space-between;gap:10px;width:100%;
        padding:12px 14px;background:var(--ink);color:var(--cream);
        border:2px solid var(--ink);font-weight:700;font-size:14px;
        text-decoration:none;cursor:pointer;transition:background .15s,color .15s,transform .15s;
      }
      .sbf-btn:hover{background:var(--c2-cond);transform:translate(-1px,-1px)}
      .sbf-btn .arrow{display:inline-flex;align-items:center;gap:0;width:18px;height:14px}
      .sbf-btn svg{width:16px;height:14px;stroke:currentColor;stroke-width:2.2;fill:none}
      .sbf-btn .meta{font-family:var(--mono);font-size:10px;font-weight:500;letter-spacing:.08em;text-transform:uppercase;opacity:.7}

      .sbf-or{position:relative;text-align:center;padding:10px 0 6px}
      .sbf-or::before{content:"";position:absolute;inset:50% 16px auto;height:1.5px;background:rgba(11,15,26,.15)}
      .sbf-or span{position:relative;background:var(--cream);padding:0 10px;font-family:var(--mono);font-size:10px;font-weight:600;letter-spacing:.12em;text-transform:uppercase;color:rgba(11,15,26,.55)}

      .sbf-secondary{padding:6px 16px 16px}
      .sbf-secondary .mini{font-family:var(--mono);font-size:10px;font-weight:600;letter-spacing:.1em;text-transform:uppercase;color:rgba(11,15,26,.55);margin-bottom:4px}
      .sbf-secondary h5{font-family:var(--narrow);font-weight:700;font-size:16px;line-height:1.15;text-transform:uppercase;letter-spacing:-.005em;margin:0 0 10px}
      .sbf-ghost{
        display:flex;align-items:center;justify-content:space-between;gap:8px;width:100%;
        padding:10px 12px;background:transparent;color:var(--ink);
        border:1.5px solid var(--ink);font-weight:600;font-size:13px;
        text-decoration:none;cursor:pointer;transition:background .15s,color .15s;
      }
      .sbf-ghost:hover{background:var(--ink);color:var(--cream)}
      .sbf-ghost svg{width:14px;height:12px;stroke:currentColor;stroke-width:2.4;fill:none}

      .sbf-handle{
        position:fixed;right:0;bottom:24px;z-index:90;
        background:var(--yellow);color:var(--ink);border:2.5px solid var(--ink);border-right:none;
        padding:12px 14px 12px 16px;font-family:var(--mono);font-size:11px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;
        cursor:pointer;display:none;align-items:center;gap:8px;
        box-shadow:-4px 4px 0 rgba(11,15,26,.25);
      }
      .sbf-handle.is-visible{display:flex}
      .sbf-handle:hover{background:var(--ink);color:var(--yellow)}
      .sbf-handle svg{width:14px;height:12px;stroke:currentColor;stroke-width:2.4;fill:none}

      @media (max-width:960px){
        .wrap { padding: 0 20px; }
        .brand .bx { display: none; } /* Hide square 'S' on mobile per request */
        .brand { font-size: 19px; }
        .nav { height: auto; align-items: stretch; }
        .cta-hd { align-self: stretch; height: auto; padding: 0 16px; border-left: 2px solid var(--ink); background: var(--ink) !important; color: var(--yellow) !important; font-size: 12px !important; }
        .agent-strip{display:none}
        .brand-mil{display:none}
        .brand-group { padding: 14px 0; gap: 8px; }

        .menu-toggle {
          display: flex;
        }

        nav.p {
          position: fixed;
          top: 96px; /* Match updated header height */
          left: 0;
          right: 0;
          background: var(--yellow);
          flex-direction: column;
          border-bottom: 2.5px solid var(--ink);
          transform: translateY(-100%);
          opacity: 0;
          transition: transform 0.3s ease, opacity 0.3s ease;
          pointer-events: none;
          z-index: 99;
        }
        nav.p.is-open {
          display: flex !important;
          transform: translateY(0);
          opacity: 1;
          pointer-events: auto;
        }
        nav.p a {
          width: 100%;
          padding: 20px 24px !important;
