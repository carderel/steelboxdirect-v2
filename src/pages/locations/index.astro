---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Shipping Containers Near You — Steel Box Direct Delivery Locations"
  description="Steel Box Direct delivers new and used shipping containers across Ohio, Indiana, and Kentucky. No broker markup, regional depots, real follow-through. Check your city."
  pageType="guide"
>
  <!-- ============ HERO ============ -->
  <section class="loc-hero">
    <div class="wrap">
      <div class="sh">
        <span class="idx">Locations</span>
        <span class="nm">Shipping Container Delivery</span>
        <span class="tg">Regional dealer · Est. 2009</span>
      </div>
      <h1 class="big">Shipping Containers<br><em>for Sale Near You.</em></h1>
      <p class="loc-lede">New and used containers delivered to your door. We work with regional depots and local drivers — no broker markup, no call center. Select your market below.</p>
    </div>
  </section>

  <!-- ============ INTRO STRIP ============ -->
  <div class="loc-intro">
    <div class="wrap">
      <p>Steel Box Direct is a regional container dealer — not a marketplace or national broker. The person quoting your container is the same person coordinating your delivery. We source from depots close to you, keep freight costs honest, and stay in contact from order to drop-off. We currently serve markets across Ohio, Indiana, and Kentucky, with more areas coming soon.</p>
    </div>
  </div>

  <!-- ============ CITY GRID ============ -->
  <section class="city-section">
    <div class="city-grid">

      <a class="city-card" href="/cincinnati-shipping-containers/">
        <div class="city-body">
          <div class="city-state-bg">OH</div>
          <div class="city-code">CIN</div>
          <div class="city-name-row">
            <span class="city-name">Cincinnati</span>
            <span class="city-state">OH</span>
          </div>
          <div class="city-region">Tri-State Area</div>
        </div>
        <div class="city-cta">Shipping containers in Cincinnati →</div>
      </a>

      <a class="city-card" href="/dayton-shipping-containers/">
        <div class="city-body">
          <div class="city-state-bg">OH</div>
          <div class="city-code">DAY</div>
          <div class="city-name-row">
            <span class="city-name">Dayton</span>
            <span class="city-state">OH</span>
          </div>
          <div class="city-region">Miami Valley</div>
        </div>
        <div class="city-cta">Shipping containers in Dayton →</div>
      </a>

      <a class="city-card" href="/indianapolis-shipping-containers/">
        <div class="city-body">
          <div class="city-state-bg">IN</div>
          <div class="city-code">IND</div>
          <div class="city-name-row">
            <span class="city-name">Indianapolis</span>
            <span class="city-state">IN</span>
          </div>
          <div class="city-region">Indy Metro</div>
        </div>
        <div class="city-cta">Shipping containers in Indianapolis →</div>
      </a>

      <a class="city-card" href="/louisville-shipping-containers/">
        <div class="city-body">
          <div class="city-state-bg">KY</div>
          <div class="city-code">LOU</div>
          <div class="city-name-row">
            <span class="city-name">Louisville</span>
            <span class="city-state">KY</span>
          </div>
          <div class="city-region">Bluegrass</div>
        </div>
        <div class="city-cta">Shipping containers in Louisville →</div>
      </a>

    </div>
  </section>

  <!-- ============ WHY LOCAL (five-section style) ============ -->
  <section class="why">
    <div class="wrap why-header">
      <div class="sh">
        <span class="idx">§ Local Advantage</span>
        <span class="nm">Why Steel Box Direct</span>
        <span class="tg">Regional dealer · Est. 2009</span>
      </div>
    </div>
    <div class="why-grid">

      <div class="why-blk why-1">
        <span class="why-lbl">§ 01 · Pricing</span>
        <div class="why-num">$0</div>
        <h3>No broker<br>markup</h3>
        <p>You deal directly with us. No middleman adding margin between you and the container yard.</p>
        <span class="why-tag">All-in pricing, always</span>
      </div>

      <div class="why-blk why-2">
        <span class="why-lbl">§ 02 · Delivery</span>
        <div class="why-num">250</div>
        <h3>Regional<br>depots</h3>
        <p>Containers pull from yards near your city. Shorter haul means lower freight and faster scheduling.</p>
        <span class="why-tag">Miles of coverage</span>
      </div>

      <div class="why-blk why-3">
        <span class="why-lbl">§ 03 · Service</span>
        <div class="why-num">1d</div>
        <h3>Real<br>follow-through</h3>
        <p>Same-day quote response. You'll know your delivery window before you commit, and we'll keep you updated at every step.</p>
        <span class="why-tag">Est. 2009 · Family owned</span>
      </div>

    </div>
  </section>

  <!-- ============ FAQ (faq-section style) ============ -->
  <section class="loc-faq">
    <div class="wrap">
      <div class="sh">
        <span class="idx">§ Common Questions</span>
        <span class="nm">Straight answers</span>
        <span class="tg">Before you ask</span>
      </div>
      <h2 class="big">The questions <em>everyone</em> asks<br>before they call.</h2>

      <div class="faq-list">

        <div class="faq-item">
          <span class="n">Q · 01</span>
          <h3 class="q">What areas do you deliver to?</h3>
          <p class="a">We currently serve markets in Ohio, Indiana, and Kentucky — including Cincinnati, Dayton, Indianapolis, and Louisville. We're expanding. If your city isn't listed, use the form below to check your ZIP.</p>
        </div>

        <div class="faq-item">
          <span class="n">Q · 02</span>
          <h3 class="q">How long does delivery take?</h3>
          <p class="a">Most deliveries land within 1–2 weeks of deposit. Depot inventory is stacked and sequenced — units aren't staged for quick pull — and drivers book out several weeks in advance. We'll give you an honest window before you commit.</p>
        </div>

        <div class="faq-item">
          <span class="n">Q · 03</span>
          <h3 class="q">What's included in the price?</h3>
          <p class="a">All-in. Container, delivery to your site, and flat-ground placement are included in the quote. No surprise freight charges after the fact. Prices reflect current market rates and are confirmed at time of order.</p>
        </div>

        <div class="faq-item">
          <span class="n">Q · 04</span>
          <h3 class="q">Do I need to be home for delivery?</h3>
          <p class="a">Not necessarily — but someone familiar with the site should be reachable by phone. The driver needs a clear run and a flat drop spot. We review site access with you before scheduling so there are no surprises on delivery day.</p>
        </div>

      </div>
    </div>
  </section>

  <!-- ============ OUT-OF-AREA CTA (bottom, cta-section style) ============ -->
  <section class="outofarea">
    <div class="inner">
      <h2 class="big">Don't see your area?<br><em>We're expanding.</em></h2>
      <p>A quote is just information. Tell us your ZIP — we'll check nearby depot inventory and freight cost before you commit to anything. If we can reach you, we'll tell you straight.</p>
      <a class="btn" href="/quote/">Check my ZIP — request a quote <svg viewBox="0 0 24 24"><path d="M5 12h14M13 5l7 7-7 7"/></svg></a>
      <div class="reassure">
        <span>No obligation</span>
        <span>Expanding to new markets</span>
        <span>Real human replies</span>
      </div>
    </div>
  </section>

  <style>
    /* Shared section header — matches homepage .sh */
    .sh{display:grid;grid-template-columns:auto 1fr auto;gap:20px;align-items:center;padding:18px 0;border-top:2px solid currentColor;border-bottom:2px solid currentColor;margin-bottom:72px}
    .sh .idx{font-family:var(--mono);font-size:var(--t-meta);letter-spacing:.08em;text-transform:uppercase}
    .sh .nm{font-family:var(--narrow);font-weight:700;font-size:22px;text-transform:uppercase;letter-spacing:-.01em}
    .sh .tg{font-family:var(--mono);font-size:var(--t-meta);letter-spacing:.08em;text-transform:uppercase;opacity:.55;text-align:right}
    .big{font-family:var(--narrow);font-weight:700;font-size:var(--t-big);line-height:.9;letter-spacing:-.02em;text-transform:uppercase;margin:0}
    .big em{font-style:italic;font-weight:700}

    /* Hero */
    .loc-hero{background:var(--yellow);color:var(--ink);padding:80px 0 64px;border-bottom:2.5px solid var(--ink)}
    .loc-hero .sh{border-color:var(--ink)}
    .loc-hero .big em{color:var(--c3-deliver)}
    .loc-lede{font-size:var(--t-lede);line-height:1.5;margin:32px 0 0;max-width:600px;font-weight:500;opacity:.85}

    /* Intro strip */
    .loc-intro{background:var(--cream);padding:40px 0;border-bottom:1.5px solid rgba(11,15,26,.15)}
    .loc-intro p{font-size:17px;line-height:1.75;opacity:.75;margin:0;max-width:760px}

    /* City grid */
    .city-section{background:var(--cream);padding:3em 0 3em;border-bottom:2.5px solid var(--ink)}
    .city-grid{display:grid;grid-template-columns:1fr 1fr;gap:.75em;width:85%;margin:0 auto}
    .city-card{display:flex;flex-direction:column;overflow:hidden;text-decoration:none;transition:transform .2s;outline:2px solid rgba(11,15,26,.07)}
    .city-card:hover{transform:translateY(-3px)}
    .city-body{background:var(--cream);padding:28px 24px 22px;position:relative;flex:1;overflow:hidden}
    .city-state-bg{position:absolute;right:12px;top:50%;transform:translateY(-50%);font-family:var(--narrow);font-weight:700;font-size:96px;letter-spacing:-.04em;color:rgba(11,15,26,.07);text-transform:uppercase;pointer-events:none;line-height:1}
    .city-code{font-family:var(--narrow);font-weight:700;color:var(--ink);font-size:clamp(44px,5vw,72px);line-height:.85;letter-spacing:-.02em;margin-bottom:10px;position:relative}
    .city-name-row{font-size:18px;text-transform:uppercase;letter-spacing:.06em;margin-bottom:4px;font-weight:700;position:relative;display:flex;align-items:baseline;gap:10px}
    .city-name{color:var(--ink)}
    .city-state{color:rgba(11,15,26,.4);font-size:14px}
    .city-region{color:rgba(11,15,26,.45);font-family:var(--mono);font-size:11px;text-transform:uppercase;letter-spacing:.08em;position:relative}
    .city-cta{background:var(--yellow);padding:14px 24px;color:var(--ink);font-family:var(--narrow);font-weight:700;font-size:16px;letter-spacing:.04em;text-transform:uppercase;transition:background .15s}
    .city-card:hover .city-cta{background:var(--c1-size)}

    /* Why — five-section style */
    .why{background:var(--ink);color:var(--cream);padding:0;border-bottom:2.5px solid var(--ink)}
    .why .why-header{padding-top:96px;padding-bottom:0}
    .why .sh{border-color:var(--cream);color:var(--cream)}
    .why-grid{display:grid;grid-template-columns:1fr 1fr 1fr;border-top:2.5px solid var(--ink)}
    .why-blk{position:relative;padding:32px 24px 28px;display:flex;flex-direction:column;gap:14px;min-height:360px;border-right:2.5px solid var(--ink);color:var(--ink);transition:transform .2s}
    .why-blk:last-child{border-right:none}
    .why-blk:hover{transform:translateY(-4px)}
    .why-num{font-family:var(--narrow);font-weight:700;font-size:clamp(80px,8vw,140px);line-height:.8;letter-spacing:-.04em;margin:0}
    .why-lbl{font-family:var(--mono);font-size:var(--t-meta);letter-spacing:.08em;text-transform:uppercase;position:absolute;top:16px;right:20px;opacity:.8}
    .why-blk h3{font-family:var(--narrow);font-weight:700;font-size:var(--t-card);line-height:.95;text-transform:uppercase;letter-spacing:-.01em;margin:0;max-width:90%}
    .why-blk p{font-size:15px;line-height:1.5;margin:0;flex:1;font-weight:500}
    .why-tag{font-family:var(--mono);font-size:10px;letter-spacing:.08em;text-transform:uppercase;padding:4px 8px;align-self:flex-start;margin-top:4px}

    .why-1{background:var(--c1-size)}
    .why-1 .why-tag{background:var(--ink);color:var(--yellow)}

    .why-2{background:var(--c3-deliver);color:var(--cream)}
    .why-2 .why-lbl{color:var(--cream)}
    .why-2 .why-tag{background:var(--cream);color:var(--c3-deliver)}

    .why-3{background:var(--c4-cost);color:var(--cream)}
    .why-3 .why-lbl{color:var(--cream)}
    .why-3 .why-tag{background:var(--cream);color:var(--c4-cost)}

    /* FAQ — faq-section style */
    .loc-faq{background:var(--c5-permits);color:var(--cream);padding:120px 0;border-bottom:2.5px solid var(--ink)}
    .loc-faq .sh{border-color:var(--cream);color:var(--cream)}
    .loc-faq .big{color:var(--cream);margin-bottom:48px}
    .loc-faq .big em{color:var(--ink);font-style:italic}
    .faq-list{border-top:2px solid var(--cream)}
    .faq-item{border-bottom:2px solid var(--cream);padding:32px 0;display:grid;grid-template-columns:60px 1fr;row-gap:16px;column-gap:32px;align-items:start}
    .faq-item .n{font-family:var(--mono);font-size:12px;letter-spacing:.08em;text-transform:uppercase;opacity:.85;padding-top:8px}
    .faq-item .q{font-family:var(--narrow);font-weight:700;font-size:clamp(26px,3.2vw,44px);line-height:1;letter-spacing:-.015em;text-transform:uppercase;margin:0;grid-column:2}
    .faq-item .a{font-size:18px;line-height:1.5;opacity:.9;grid-column:2;margin:0;max-width:760px;font-weight:500}

    /* Out-of-area CTA — cta-section style */
    .outofarea{background:var(--yellow);color:var(--ink);padding:140px 0 120px;border-bottom:2.5px solid var(--ink);position:relative;overflow:hidden}
    .outofarea .inner{max-width:1200px;margin:0 auto;padding:0 32px;text-align:center;position:relative;z-index:1}
    .outofarea .big{font-size:clamp(30px,5.5vw,90px);line-height:.84;margin-bottom:32px}
    .outofarea .big em{color:var(--c3-deliver)}
    .outofarea p{font-size:22px;line-height:1.4;max-width:640px;margin:0 auto 40px;font-weight:500}
    .outofarea .btn{padding:22px 32px;font-size:18px}
    .reassure{margin-top:40px;display:flex;gap:36px;justify-content:center;flex-wrap:wrap;font-family:var(--mono);font-size:11px;letter-spacing:.08em;text-transform:uppercase;opacity:.65}
    .reassure span::before{content:"●";margin-right:8px;color:var(--c4-cost)}

    @media(max-width:960px){
      .city-grid{grid-template-columns:1fr 1fr}
      .why-grid{grid-template-columns:1fr}
      .why-blk{border-right:none;border-bottom:2.5px solid var(--ink);min-height:280px}
      .why-blk:last-child{border-bottom:none}
      .faq-item{grid-template-columns:1fr;gap:12px}
      .faq-item .q,.faq-item .a{grid-column:1}
    }

    @media(max-width:720px){
      .city-grid{grid-template-columns:1fr}
.sh{grid-template-columns:auto 1fr;row-gap:6px}
      .sh .tg{grid-column:1 / -1;text-align:left;opacity:.5}
      .big{font-size:clamp(36px,9vw,64px)}
    }
  </style>
</BaseLayout>
