    position: relative; z-index: 1; margin: 0;
    color: var(--cream); opacity: .7; padding: 14px 16px;
    border-top: 1px solid rgba(246,241,231,.18);
    background: linear-gradient(transparent, rgba(11,15,26,.55));
    width: 100%; letter-spacing: .06em; line-height: 1.4;
