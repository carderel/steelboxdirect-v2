              </figure>
            )}
          </div>
        ))}
      </div>

      <div class="uc-sources">
        <span class="m">Sources</span>
        <ul>
          <li>Container interior height &amp; 40ft dimensions — <a href="https://www.icontainers.com/help/40-foot-container/" target="_blank" rel="noopener">iContainers, 40-foot container spec</a></li>
          <li>Container steel — <a href="https://en.wikipedia.org/wiki/Weathering_steel" target="_blank" rel="noopener">Weathering (Cor-Ten) steel</a></li>
          <li>Depreciation treatment — <a href="https://www.irs.gov/publications/p946" target="_blank" rel="noopener">IRS Publication 946, How To Depreciate Property</a></li>
        </ul>
      </div>
    </div>
  </section>

  <!-- 6. CTA -->
  <section class="guide-product-cta" style="padding: 64px 0; background: var(--ink); color: var(--cream);">
    <div class="wrap" style="display: flex; flex-direction: column; align-items: flex-start; gap: 24px; max-width: 680px;">
      <p class="m" style="color: var(--yellow); margin: 0;">Ready when you are</p>
      <h2 style="font-family: var(--narrow); font-size: clamp(28px, 4vw, 44px); font-weight: 700; text-transform: uppercase; margin: 0; line-height: 1.05;">Get a quote for your operation.</h2>
      <p style="font-size: 17px; opacity: .75; margin: 0; line-height: 1.5;">Tell us your inventory volume, how many units you need, and your delivery zip — single site or several. We respond within 4 business hours with an all-in number.</p>
      <div style="display: flex; gap: 16px; flex-wrap: wrap;">
        <a href="/quote/" class="btn" style="background: var(--yellow); color: var(--ink); border-color: var(--yellow);">Get My Quote →</a>
