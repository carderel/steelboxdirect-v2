---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Seller Login | Steel Box Direct" pageType="legal" noindex={true}>
  <div class="login-container">
    <div class="wrap">
      <div class="login-box">
        <div class="m" style="margin-bottom: 24px; color: var(--c5-permits);">Restricted Access</div>
        <h1>Seller Console</h1>
        <p>Log in to manage leads and quote requests.</p>
        
        <form id="login-form" class="login-form">
          <div class="form-group">
            <label for="email">Email</label>
            <input type="email" id="email" name="email" required placeholder="your@email.com" />
          </div>
          <div class="form-group">
            <label for="password">Password</label>
            <input type="password" id="password" name="password" required />
          </div>
          <button type="submit" class="btn" style="width: 100%; justify-content: center;">Sign In</button>
          <div id="login-error" class="error-msg" style="display: none;"></div>
          <div id="login-status" class="status-msg" style="display: none;"></div>
          <button type="button" id="forgot-password" class="forgot-link">Forgot password?</button>
        </form>
      </div>
    </div>
  </div>

  <script>
    import { supabase } from '../../lib/supabase';

    const form = document.getElementById('login-form') as HTMLFormElement;
    const errorDiv = document.getElementById('login-error');
    const statusDiv = document.getElementById('login-status');
    const forgotBtn = document.getElementById('forgot-password');

    forgotBtn?.addEventListener('click', async () => {
      const emailInput = document.getElementById('email') as HTMLInputElement;
      const email = emailInput?.value?.trim();

      if (errorDiv) {
        errorDiv.style.display = 'none';
        errorDiv.textContent = '';
      }
      if (statusDiv) {
        statusDiv.style.display = 'none';
        statusDiv.textContent = '';
      }

      if (!email) {
        if (errorDiv) {
          errorDiv.style.display = 'block';
          errorDiv.textContent = 'Enter your email first';
        }
        return;
      }

      try {
        const { error } = await supabase.auth.resetPasswordForEmail(email, {
          redirectTo: window.location.origin + '/admin/reset',
        });
        if (error) {
          if (errorDiv) {
            errorDiv.style.display = 'block';
            errorDiv.textContent = error.message;
          }
        } else if (statusDiv) {
          statusDiv.style.display = 'block';
          statusDiv.textContent = 'Check your email for a reset link.';
        }
      } catch (err: any) {
        if (errorDiv) {
          errorDiv.style.display = 'block';
          errorDiv.textContent = 'An unexpected error occurred.';
        }
      }
    });

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const formData = new FormData(form);
      const email = formData.get('email') as string;
      const password = formData.get('password') as string;

      console.log('Auth: Attempting sign-in...', { email });

      if (errorDiv) {
        errorDiv.style.display = 'none';
        errorDiv.textContent = '';
      }

      try {
        const { data, error } = await supabase.auth.signInWithPassword({
          email,
          password,
        });

        if (error) {
          console.error('Auth Error:', error);
          if (errorDiv) {
            errorDiv.style.display = 'block';
            errorDiv.textContent = error.message;
          }
        } else {
          console.log('Auth Success:', data.user?.id);
          window.location.href = '/admin/dashboard';
        }
      } catch (err: any) {
        console.error('Auth Exception:', err);
        if (errorDiv) {
          errorDiv.style.display = 'block';
          errorDiv.textContent = 'An unexpected error occurred.';
        }
      }
    });

    // Check if already logged in
    async function checkSession() {
      const { data: { session } } = await supabase.auth.getSession();
      if (session) {
        window.location.href = '/admin/dashboard';
      }
    }
    checkSession();
  </script>

  <style>
    .login-container {
      padding: 120px 0;
      background: var(--cream);
      min-height: 80vh;
      display: flex;
      align-items: center;
    }
    .login-box {
      max-width: 480px;
      margin: 0 auto;
      background: white;
      border: 2px solid var(--ink);
      padding: 48px;
      box-shadow: 12px 12px 0 var(--ink);
    }
    .login-box h1 {
      font-family: var(--narrow);
      font-size: 32px;
      text-transform: uppercase;
      margin-bottom: 8px;
    }
    .login-box p {
      opacity: .7;
      margin-bottom: 32px;
    }
    .form-group {
      margin-bottom: 24px;
    }
    .form-group label {
      display: block;
      font-family: var(--mono);
      font-size: 11px;
      text-transform: uppercase;
      margin-bottom: 8px;
      opacity: .6;
    }
    .form-group input {
      width: 100%;
      padding: 14px;
      border: 2px solid var(--ink);
      font-family: var(--display);
      font-size: 16px;
      background: var(--cream);
    }
    .error-msg {
      margin-top: 20px;
      color: var(--c2-cond);
      font-size: 14px;
      font-weight: 600;
    }
    .status-msg {
      margin-top: 20px;
      color: var(--c5-permits);
      font-size: 14px;
      font-weight: 600;
    }
    .forgot-link {
      display: block;
      margin-top: 20px;
      background: none;
      border: none;
      padding: 0;
      cursor: pointer;
      font-family: var(--mono);
      font-size: 12px;
      text-transform: uppercase;
      color: var(--ink);
      opacity: .7;
      text-decoration: underline;
    }
    .forgot-link:hover {
      opacity: 1;
    }
  </style>
</BaseLayout>
