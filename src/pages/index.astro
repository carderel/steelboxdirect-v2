---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroSection from '../components/home/HeroSection.astro';
import ProblemSection from '../components/home/ProblemSection.astro';
import FiveSection from '../components/home/FiveSection.astro';
import RigSection from '../components/home/RigSection.astro';
import PersonasSection from '../components/home/PersonasSection.astro';
import PriceSection from '../components/home/PriceSection.astro';
import FaqSection from '../components/home/FaqSection.astro';
import CtaSection from '../components/home/CtaSection.astro';
import { CONDITION } from '../data/condition';
---
<BaseLayout
  title="Shipping & Storage Containers for Sale — Ohio, Indiana & Kentucky | Steel Box Direct"
  description={`Buy a 20ft, 40ft, or 40ft High Cube shipping & storage container delivered within 250 miles of Cincinnati. No broker markup. ${CONDITION.label} steel. Quote within 4 business hours.`}
  pageType="home"
>
  <HeroSection />
  <ProblemSection />
  <FiveSection />
  <RigSection />
  <PersonasSection />
  <PriceSection />
  <FaqSection />
  <CtaSection />
</BaseLayout>
