---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import heroImage from '../assets/photos/container-blue-weathered.jpg';
import containerHero from '../assets/photos/40ft-container-hero-reduced2.png';
import rigDiagram from '../assets/photos/delivery-rig-diagram.png';
---

<BaseLayout
  title="Shipping Containers for Sale — Ohio, Indiana & Kentucky | Steel Box Direct"
  description="Buy a 20ft or 40ft shipping container delivered within 250 miles of Cincinnati. No broker markup. Cargo-worthy and one-trip units. Quote within 4 business hours."
  pageType="home"
>
  <link slot="head" rel="preconnect" href="https://fonts.googleapis.com" />
  <link slot="head" rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link slot="head" href="https://fonts.googleapis.com/css2?family=Permanent+Marker&display=swap" rel="stylesheet" />
  <!-- ============ HERO ============ -->
  <section class="hero">
    <div class="wrap">
      <div class="hero-grid">
        <div class="hz hz-1">
          <h1 class="billboard">Shipping Containers That Actually Show Up.</h1>
          <p class="hero-sub">20ft &amp; 40ft units delivered to your door. No call centers, no runaround.</p>
        </div>
        <div class="hz hz-2"><span>2</span></div>
        <div class="hz hz-3"><span>3</span></div>
        <div class="hz hz-4"><span>4</span></div>
        <div class="hz hz-5"><span>5</span></div>
      </div>
    </div>
  </section>

  <!-- Ticker under hero -->
  <div class="ticker" aria-hidden="true">
    <div class="track ticker_track">
      <span>Delivery included within <em>250 miles</em></span><span>●</span>
      <span>Great for <em>farm &amp; ranch storage</em></span><span>●</span>
      <span>Perfect for <em>job site security</em></span><span>●</span>
      <span>Most farm storage is <em>zoned exempt</em></span><span>●</span>
      <span>Ideal for <em>backyard workshops</em></span><span>●</span>
      <span>400+ containers placed across OH · IN · KY</span><span>●</span>
      <span>Built for <em>commercial inventory</em></span><span>●</span>
      <span>No farm-access upcharge</span><span>●</span>
      <span>Convert into an <em>office or studio</em></span><span>●</span>
      <span>Delivery included within <em>250 miles</em></span><span>●</span>
      <span>Great for <em>farm &amp; ranch storage</em></span><span>●</span>
      <span>Perfect for <em>job site security</em></span><span>●</span>
      <span>Most farm storage is <em>zoned exempt</em></span><span>●</span>
      <span>Ideal for <em>backyard workshops</em></span><span>●</span>
      <span>400+ containers placed across OH · IN · KY</span><span>●</span>
      <span>Built for <em>commercial inventory</em></span><span>●</span>
      <span>No farm-access upcharge</span><span>●</span>
      <span>Convert into an <em>office or studio</em></span><span>●</span>
    </div>
  </div>

  <!-- ============ §01 PROBLEM ============ -->
  <section class="problem">
    <div class="wrap problem_wrap">
      <div class="sh">
        <span class="idx">§ 01</span>
        <span class="nm">The Problem</span>
        <span class="tg">Why we built this</span>
      </div>
      <h2 class="big">Most sellers jump<br>straight to <em>the sale.</em></h2>
      <div class="row problem_row">
        <div class="problem_lede_col">
          <p class="lede problem_lede">A container is a <mark>25-year investment.</mark> The difference between the right one and the wrong one is years of protection — or a rusted-out headache. Before you sign anything, you deserve to understand what you're buying.</p>
          <div class="warranty-stamp problem_warranty">
            <span class="w-small">Lifetime</span>
            <span class="w-outline">Warranty.</span>
            <span class="warranty-sub">on every unit we place.</span>
          </div>
        </div>
        <div class="problem_stats">
          <div class="stat problem_stat">
            <div class="num c2">25yr</div>
            <div class="problem_stat_copy">
              <div class="lbl problem_stat_label">Useful life</div>
              <div class="txt problem_stat_text">A properly-placed steel box outlasts most pole barns for a fraction of the price.</div>
            </div>
          </div>
          <div class="stat problem_stat">
            <div class="num c3">400+</div>
            <div class="problem_stat_copy">
              <div class="lbl problem_stat_label">Units placed</div>
              <div class="txt problem_stat_text">Across farms, workshops, breweries, and hobby properties — wherever the truck can reach — since 2009.</div>
            </div>
          </div>
          <div class="stat problem_stat">
            <div class="num c4">0</div>
            <div class="problem_stat_copy">
              <div class="lbl problem_stat_label">Hidden fees</div>
              <div class="txt problem_stat_text">All-in pricing. Container, delivery, setup. What we quote is what you pay.</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ §02 THE FIVE ============ -->
  <section class="five" id="five">
    <div class="wrap wrap-top five_header">
      <div class="sh">
        <span class="idx">§ 02</span>
        <span class="nm">The Five Decisions</span>
        <span class="tg">Est. 5 min / decision</span>
      </div>
      <div class="intro five_intro">
        <h2 class="big">Five decisions<br>stand between you<br>and <em>the right container.</em></h2>
        <p>Work through them in order. Each guide answers the question buyers like you — Tom, Sarah, Mike — actually ask. No sales pitch, no jargon.</p>
      </div>
    </div>

    <div class="grid5 five_grid">
      <a class="blk blk-1" href="/size/">
        <span class="lbl">§ 01 · Size</span>
        <div class="num">01</div>
        <h3>What size do you need?</h3>
        <p>A 20-foot holds one tractor. A 40-foot is your full arsenal. 40 High-Cube if you've got a tall implement.</p>
        <span class="who">→ Tom · 40-ft primary</span>
        <span class="go">Open size guide <svg viewBox="0 0 24 24"><path d="M5 12h14M13 5l7 7-7 7"/></svg></span>
      </a>
      <a class="blk blk-2" href="/condition/">
        <span class="lbl">§ 02 · Condition</span>
        <div class="num">02</div>
        <h3>New or used?</h3>
        <p>New guarantees protection. Used saves money. Both work — it just depends on what you're protecting and for how long.</p>
        <span class="who">→ The Sweet Spot: cargo-worthy</span>
        <span class="go">Open condition guide <svg viewBox="0 0 24 24"><path d="M5 12h14M13 5l7 7-7 7"/></svg></span>
      </a>
      <a class="blk blk-3" href="/delivery/">
        <span class="lbl">§ 03 · Delivery</span>
        <div class="num">03</div>
        <h3>Will it even get here?</h3>
        <p>Narrow lanes, soft ground, low branches — we plan for it. Tilt-bed for firm ground, crane-set for tight or rural access.</p>
        <span class="who">→ Mike · rural access</span>
        <span class="go">Open delivery guide <svg viewBox="0 0 24 24"><path d="M5 12h14M13 5l7 7-7 7"/></svg></span>
      </a>
      <a class="blk blk-4" href="/cost/">
        <span class="lbl">§ 04 · Cost</span>
        <div class="num">04</div>
        <h3>What will it really cost?</h3>
        <p>All-in. Container, delivery, setup. No surprise fees. Fair regional pricing — no premium just because you're rural.</p>
        <span class="who">→ Sarah · multi-unit</span>
        <span class="go">Open pricing guide <svg viewBox="0 0 24 24"><path d="M5 12h14M13 5l7 7-7 7"/></svg></span>
      </a>
      <a class="blk blk-5" href="/permits/">
        <span class="lbl">§ 05 · Permits</span>
        <div class="num">05</div>
        <h3>Do I need a permit?</h3>
        <p>Usually no. Most farm storage is zoned-exempt in OH, IN, and KY. Commercial use or HOAs — we'll tell you straight.</p>
        <span class="who">→ Ag-exempt in most counties</span>
        <span class="go">Open permit guide <svg viewBox="0 0 24 24"><path d="M5 12h14M13 5l7 7-7 7"/></svg></span>
      </a>
    </div>
  </section>

  <!-- ============ §04 THE RIG (Embece slab) ============ -->
  <section class="rig" id="rig">
    <div class="top-type wrap rig_header">
      <h2 class="wordmark"><span>THE&nbsp;RIG</span> · SPECS</h2>
    </div>
    <div class="rig-inner rig_inner">
      <div class="photo rig_photo">
        <div class="photo-frame rig_photo_frame">
          <Image src={heroImage} alt="40-ft cargo-worthy container on a rural property" width={1100} height={550} format="webp" />
          <span class="fig">FIG. 003 — Site placement</span>
          <span class="cap">40 × 8 × 8'6" · placed Brown County, IN · March 2020</span>
        </div>
      </div>
      <div class="grid-below rig_specs_grid">
        <div class="spec rig_spec_item">
          <span class="lbl">Footprint</span>
          <span class="val">320 sq ft</span>
          <span class="note">The 40-ft holds a mid-size tractor with room for a grain drill or a pallet-deep shelving run.</span>
        </div>
        <div class="spec rig_spec_item">
          <span class="lbl">Interior height</span>
          <span class="val">8' 6" HC</span>
          <span class="note">High-cube adds 12" of headroom. Clears most utility tractors with ROPS folded.</span>
        </div>
        <div class="spec rig_spec_item">
          <span class="lbl">Door opening</span>
          <span class="val">7' 9" wide</span>
          <span class="note">Double cargo doors open 270° and lock flat to the sidewall. No ramp required for most equipment.</span>
        </div>
      </div>
      <div class="rig-diagram-wrap">
        <div class="rig-diagram-inner">
          <Image src={rigDiagram} alt="Labeled diagram of a shipping container showing structural components including corner posts, rails, corrugated roof, locking bars, door sill, and floor cross members" class="rig-diagram-img" />
        </div>
      </div>
    </div>
  </section>

  <!-- ============ §05 PERSONAS TABLE ============ -->
  <section class="personas">
    <div class="wrap personas_wrap">
      <div class="sh">
        <span class="idx">§ 03</span>
        <span class="nm">Who buys from us</span>
        <span class="tg">Three common stories</span>
      </div>
      <div class="intro personas_intro">
        <h2 class="big">If any of this<br>sounds like <em>you</em> —<br>we've done it before.</h2>
        <p>We've placed 400+ containers across the region. Most of our customers are one of three people. Here's what they bought and why.</p>
      </div>

      <table class="ptbl">
        <thead>
          <tr>
            <th>Buyer</th>
            <th>They said</th>
            <th>We recommended</th>
            <th>Why it fit</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td>
              <div class="pname persona_name">
                <span class="dot" style="background:var(--c1-size)"></span>
                <span class="pcol"><b>Tom</b><small>Equipment farmer</small></span>
              </div>
            </td>
            <td class="quote">"Won't it rust? Will it protect my equipment long-term?"</td>
            <td><a href="/shipping-containers-for-sale/40-foot-one-trip-container/" class="rec-link"><span class="rec">40-ft · one-trip</span></a></td>
            <td>New steel for 25-year weather protection on a John Deere and a grain drill. Sited on crushed stone, leveled with railroad ties.</td>
          </tr>
          <tr>
            <td>
              <div class="pname persona_name">
                <span class="dot" style="background:var(--c3-deliver)"></span>
                <span class="pcol"><b>Sarah</b><small>Diversified business owner</small></span>
              </div>
            </td>
            <td class="quote">"Can we make this look professional? Scale to multiple units?"</td>
            <td><a href="/shipping-containers-for-sale/40-foot-shipping-container/" class="rec-link"><span class="rec">2 × 40-ft · mixed</span></a></td>
            <td>One one-trip for customer-facing inventory, one cargo-worthy for back-stock. Painted to match the barn.</td>
          </tr>
          <tr>
            <td>
              <div class="pname persona_name">
                <span class="dot" style="background:var(--c5-permits)"></span>
                <span class="pcol"><b>Mike</b><small>Hobby / rural</small></span>
              </div>
            </td>
            <td class="quote">"Can you deliver to my property? Is used okay?"</td>
            <td><a href="/shipping-containers-for-sale/20-foot-shipping-container/" class="rec-link"><span class="rec">20-ft · cargo-worthy</span></a></td>
            <td>Crane-set over a fenceline at the end of a gravel lane. Cargo-worthy for a 2/3 cost savings — horse trailer and tools stay dry.</td>
          </tr>
        </tbody>
      </table>
    </div>
  </section>

  <!-- ============ §06 PRICING TEASER ============ -->
  <section class="price" id="price">
    <div class="wrap pricing_wrap">
      <div class="sh">
        <span class="idx">§ 04</span>
        <span class="nm">What it really costs</span>
        <span class="tg">All-in · no hidden fees</span>
      </div>
      <h2 class="big">Three price points.<br><em>One honest number</em> each.</h2>
      <p class="intro">These are recent averages — container, delivery, and placement on flat ground included. Container prices fluctuate with market availability. <a href="/quote/" style="color:inherit;border-bottom:1.5px solid currentColor">Submit a quote</a> for current pricing.</p>

      <div class="pgrid pricing_grid">
        <div class="pcard pricing_card">
          <div class="tag pricing_name"><span class="name">20-ft cargo</span><span class="chip">Most available</span></div>
          <ul class="pricing_features">
            <li>~160 sq ft · fits a tractor or a lot of tools</li>
            <li>Wind &amp; Water Tight, minor surface rust</li>
            <li>Next-week delivery usually available</li>
          </ul>
          <a href="/shipping-containers-for-sale/20-foot-shipping-container/" class="pcard-cta pricing_cta">See full specs <span>→</span></a>
        </div>
        <div class="pcard rec pricing_card">
          <div class="tag pricing_name"><span class="name">40-ft cargo</span><span class="chip">Most popular</span></div>
          <ul class="pricing_features">
            <li>~320 sq ft · equipment + implements + shelving</li>
            <li>The Sweet Spot — best value per square foot</li>
            <li>Fits farms, job sites, and commercial properties</li>
          </ul>
          <a href="/shipping-containers-for-sale/40-foot-shipping-container/" class="pcard-cta pricing_cta">See full specs <span>→</span></a>
        </div>
        <div class="pcard pricing_card">
          <div class="tag pricing_name"><span class="name">40-ft one-trip</span><span class="chip">New</span></div>
          <ul class="pricing_features">
            <li>Single trip from factory · factory finish</li>
            <li>25-year weather protection, warranty-backed</li>
            <li>Best choice for conversions and builds</li>
          </ul>
          <a href="/shipping-containers-for-sale/40-foot-one-trip-container/" class="pcard-cta pricing_cta">See full specs <span>→</span></a>
        </div>
      </div>
      <p style="font-family:var(--mono);font-size:13px;letter-spacing:.04em;font-weight:500;opacity:.7;text-transform:uppercase;margin-top:2rem;line-height:1.75">
        Container pricing tracks global shipping rates and steel supply — it shifts week to week. We don't post numbers that will be wrong by the time you read them. Request a quote for the current price that applies to your order.
      </p>
    </div>
  </section>

  <!-- ============ §07 FAQ ============ -->
  <section class="faq" id="faq">
    <div class="wrap faq_wrap">
      <div class="sh">
        <span class="idx">§ 05</span>
        <span class="nm">Straight answers</span>
        <span class="tg">Before you ask</span>
      </div>
      <h2 class="big">The questions <em>everyone</em> asks<br>before they send a deposit.</h2>

      <div class="faq-list faq_list">
        <div class="faq-item faq_item">
          <span class="n">Q · 01</span>
          <h3 class="q">Won't it rust out on me?</h3>
          <p class="a">Corten steel, painted inside and out. On crushed-stone pads with airflow underneath, 25 years is realistic. We'll show you how to prep the site.</p>
        </div>
        <div class="faq-item faq_item">
          <span class="n">Q · 02</span>
          <h3 class="q">Can you get it back my driveway?</h3>
          <p class="a">Usually yes. Tilt-bed needs ~100 ft of approach and firm ground. For tight or soft sites, crane-set works — no lane damage. We'll scout before we schedule.</p>
        </div>
        <div class="faq-item faq_item">
          <span class="n">Q · 03</span>
          <h3 class="q">Do I need a permit?</h3>
          <p class="a">For farm storage in OH, IN, and KY: almost never. Commercial use or an HOA changes things — we'll flag it on the call, not after you pay.</p>
        </div>
        <div class="faq-item faq_item">
          <span class="n">Q · 04</span>
          <h3 class="q">Is used actually safe for my equipment?</h3>
          <p class="a">Cargo-worthy units are structurally certified and weather-tight. Surface rust is cosmetic. For anything irreplaceable, we still steer you to one-trip.</p>
        </div>
        <div class="faq-item faq_item">
          <span class="n">Q · 05</span>
          <h3 class="q">How quickly can you get it here?</h3>
          <p class="a">Most deliveries land within 1–2 weeks of deposit. Depot inventory is stacked and sequenced — units aren't staged for quick pull — and drivers book out several weeks in advance, so exact timing depends on current availability. We'll give you an honest window before you commit, and you'll hear from us at every step until it's on your property.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ §08 CTA ============ -->
  <section class="cta" id="cta">
    <div class="inner cta_inner">
      <h2 class="big">Ready? <em>Let's talk.</em></h2>
      <p>A quote is just information. Tell us what you're protecting — we'll send a real number and a delivery window. Usually same day.</p>
      <a class="btn" href="/quote/">Get my quote <svg viewBox="0 0 24 24"><path d="M5 12h14M13 5l7 7-7 7"/></svg></a>
      <div class="reassure cta_reassure">
        <span>No obligation</span>
        <span>Real human replies</span>
        <span>All-in pricing, always</span>
      </div>
      <p style="margin-top:2rem;font-family:var(--mono);font-size:11px;letter-spacing:.06em;text-transform:uppercase;opacity:.6">Serving <a href="/cincinnati-shipping-containers/" style="color:inherit;border-bottom:1px solid currentColor">Cincinnati</a> · <a href="/dayton-shipping-containers/" style="color:inherit;border-bottom:1px solid currentColor">Dayton</a> · <a href="/indianapolis-shipping-containers/" style="color:inherit;border-bottom:1px solid currentColor">Indianapolis</a> · <a href="/louisville-shipping-containers/" style="color:inherit;border-bottom:1px solid currentColor">Louisville</a> and surrounding areas — <a href="/locations/" style="color:inherit;border-bottom:1px solid currentColor">see full delivery map</a></p>
    </div>
  </section>

  <style>
    /* Hero scaffold */
    .hero{background:var(--yellow);color:var(--ink);border-bottom:2.5px solid var(--ink);padding:32px 0}
    .hero-grid{
      display:grid;
      grid-template-areas:"one one" "two three" "four five";
      grid-template-columns:3fr 2fr;
      border:2.5px solid var(--ink);
    }
    .hz{display:flex;align-items:center;justify-content:center;border:2px solid var(--ink);font-family:var(--mono);font-size:32px;font-weight:700;color:white}
    .hz span{background:rgba(0,0,0,.35);padding:8px 18px;border-radius:2px}
    .hz-1{grid-area:one;background:var(--yellow);color:var(--ink);align-items:flex-start;flex-direction:column;padding:48px 40px 40px;gap:16px}
    .billboard{font-family:var(--narrow);font-weight:700;font-size:clamp(20px,3vw,48px);line-height:1;letter-spacing:-.02em;text-transform:uppercase;margin:0;white-space:nowrap}
    .hero-sub{font-family:var(--narrow);font-size:clamp(14px,1.6vw,22px);font-weight:500;line-height:1.2;margin:0;opacity:.75;text-align:right}
    .hz-2{grid-area:two;background:#ffffff;color:var(--ink);min-height:220px}
    .hz-2 span{background:rgba(0,0,0,.08)}
    .hz-3{grid-area:three;background:#8b4d4d;min-height:220px}
    .hz-4{grid-area:four;background:#2d0a0a;min-height:120px}
    .hz-5{grid-area:five;background:#4a6fa5;min-height:120px}

    /* Ticker */
    .ticker{background:var(--ink);color:var(--yellow);border-top:2.5px solid var(--ink);border-bottom:2.5px solid var(--ink);overflow:hidden;white-space:nowrap;padding:14px 0;font-family:var(--narrow);font-weight:700;font-size:20px;text-transform:uppercase;letter-spacing:-.01em}
    .ticker .track{display:inline-block;animation:tkr 38s linear infinite;padding-left:100%}
    .ticker span{margin:0 24px}
    .ticker em{font-style:normal;color:var(--c5-permits)}
    @keyframes tkr{from{transform:translateX(0)}to{transform:translateX(-100%)}}

    /* Sections Shared */
    .sh{display:grid;grid-template-columns:auto 1fr auto;gap:20px;align-items:center;padding:18px 0;border-top:2px solid var(--ink);border-bottom:2px solid var(--ink);margin-bottom:72px}
    .sh .idx{font-family:var(--mono);font-size:var(--t-meta);letter-spacing:.08em;text-transform:uppercase}
    .sh .nm{font-family:var(--narrow);font-weight:700;font-size:22px;text-transform:uppercase;letter-spacing:-.01em}
    .sh .tg{font-family:var(--mono);font-size:var(--t-meta);letter-spacing:.08em;text-transform:uppercase;opacity:.55;text-align:right}
    .big{font-family:var(--narrow);font-weight:700;font-size:var(--t-big);line-height:.9;letter-spacing:-.02em;text-transform:uppercase;margin:0}
    .big em{font-style:italic;color:var(--c5-permits);font-weight:700}

    /* Problem */
    .problem{background:var(--cream);padding:120px 0 2em;border-bottom:2.5px solid var(--ink);position:relative;overflow:hidden}
    .problem .row{display:grid;grid-template-columns:1.1fr 1fr;gap:72px;align-items:start;margin-top:56px}
    .problem .problem_lede_col{display:flex;flex-direction:column}
    .problem .lede{font-size:22px;line-height:1.45;margin:0 0 32px;max-width:560px;font-weight:500}
    .problem .lede mark{background:var(--yellow);color:var(--ink);padding:1px 6px;box-decoration-break:clone;-webkit-box-decoration-break:clone}
    .warranty-stamp{margin-top:auto;margin-left:auto;margin-right:auto;display:flex;flex-direction:column;gap:0;transform:rotate(-15deg);transform-origin:left bottom;padding-top:2em}
    .w-small{font-family:'Permanent Marker',cursive;font-size:clamp(60px,8vw,92px);color:var(--ink);line-height:1;margin-bottom:-10px}
    .w-outline{font-family:'Permanent Marker',cursive;font-size:clamp(52px,7vw,80px);color:var(--ink);line-height:1;margin-left:0.7em}
    .warranty-sub{font-family:var(--mono);font-size:11px;letter-spacing:.08em;text-transform:uppercase;opacity:.5;margin-top:10px;transform:rotate(15deg);transform-origin:left center}
    .stat{display:grid;grid-template-columns:auto 1fr;gap:22px;padding:22px 0;border-top:1.5px solid var(--ink);align-items:baseline}
    .stat:last-child{border-bottom:1.5px solid var(--ink)}
    .stat .num{font-family:var(--narrow);font-weight:700;font-size:64px;line-height:.85;letter-spacing:-.02em}
    .stat .num.c2{color:var(--c2-cond)}
    .stat .num.c3{color:var(--c3-deliver)}
    .stat .num.c4{color:var(--c4-cost)}
    .stat .lbl{font-family:var(--mono);font-size:var(--t-meta);letter-spacing:.08em;text-transform:uppercase;opacity:.55;margin-bottom:4px}
    .stat .txt{font-size:16px;line-height:1.45}

    /* Five */
    .five{background:var(--ink);color:var(--cream);padding:0;border-bottom:2.5px solid var(--ink)}
    .five .wrap-top{padding-top:96px;padding-bottom:48px}
    .five .sh{border-color:var(--cream);color:var(--cream)}
    .five .big{color:var(--cream)}
    .five .big em{color:var(--yellow)}
    .five .intro{display:grid;grid-template-columns:1.2fr 1fr;gap:56px;align-items:end;margin:56px 0 0}
    .five .intro p{font-size:var(--t-lede);line-height:1.5;margin:0;max-width:460px;opacity:.85}

    .grid5{display:grid;grid-template-columns:repeat(5,1fr);border-top:2.5px solid var(--ink)}
    .blk{position:relative;padding:32px 24px 28px;display:flex;flex-direction:column;gap:14px;min-height:520px;border-right:2.5px solid var(--ink);color:var(--ink);transition:transform .2s}
    .blk:last-child{border-right:none}
    .blk:hover{transform:translateY(-4px)}
    .blk .num{font-family:var(--narrow);font-weight:700;font-size:clamp(90px,8vw,140px);line-height:.8;letter-spacing:-.04em;margin:0}
    .blk .lbl{font-family:var(--mono);font-size:var(--t-meta);letter-spacing:.08em;text-transform:uppercase;position:absolute;top:16px;right:20px}
    .blk h3{font-family:var(--narrow);font-weight:700;font-size:var(--t-card);line-height:.95;text-transform:uppercase;letter-spacing:-.01em;margin:0;max-width:90%}
    .blk p{font-size:15px;line-height:1.5;margin:0;flex:1;font-weight:500}
    .blk .who{font-family:var(--mono);font-size:10px;letter-spacing:.08em;text-transform:uppercase;padding:4px 8px;background:var(--ink);color:var(--cream);align-self:flex-start;margin-top:4px}
    .blk .go{font-family:var(--narrow);font-weight:700;font-size:15px;text-transform:uppercase;letter-spacing:.01em;display:inline-flex;align-items:center;gap:10px;border-top:1.5px solid var(--ink);padding-top:14px;margin-top:auto}
    .blk .go svg{width:16px;height:16px;stroke:currentColor;stroke-width:2.6;fill:none;transition:transform .15s}
    .blk:hover .go svg{transform:translateX(6px)}

    .blk-1{background:var(--c1-size)}
    .blk-2{background:var(--c2-cond);color:var(--cream)}
    .blk-2 .go{border-top-color:var(--cream)}
    .blk-2 .who{background:var(--cream);color:var(--c2-cond)}
    .blk-3{background:var(--c3-deliver);color:var(--cream)}
    .blk-3 .go{border-top-color:var(--cream)}
    .blk-3 .who{background:var(--cream);color:var(--c3-deliver)}
    .blk-4{background:var(--c4-cost);color:var(--cream)}
    .blk-4 .go{border-top-color:var(--cream)}
    .blk-4 .who{background:var(--cream);color:var(--c4-cost)}
    .blk-5{background:var(--c5-permits);color:var(--cream)}
    .blk-5 .go{border-top-color:var(--cream)}
    .blk-5 .who{background:var(--cream);color:var(--c5-permits)}

    /* Rig */
    .rig{background:var(--c3-deliver);color:var(--cream);padding:0;border-bottom:2.5px solid var(--ink);position:relative;overflow:hidden}
    .rig .top-type{padding-top:56px;position:relative}
    .rig .wordmark{font-family:var(--narrow);font-weight:700;font-size:clamp(56px,11vw,220px);line-height:.9;letter-spacing:-.03em;text-transform:uppercase;margin:0;white-space:nowrap;transform:translateX(-1%);position:relative;z-index:1}
    .rig .wordmark span{-webkit-text-stroke:2px var(--cream);color:transparent}

    .rig-inner{padding:0 0 96px;margin-top:-60px;position:relative;z-index:2}
    .rig .photo{margin:0 auto;max-width:1100px;padding:0 32px}
    .rig .photo-frame{aspect-ratio:16/8;background:var(--ink);border:2.5px solid var(--ink);overflow:hidden;position:relative}
    .rig .photo-frame img{width:100%;height:100%;object-fit:cover;display:block}
    .rig .photo-frame .cap{position:absolute;left:16px;bottom:16px;background:var(--cream);color:var(--ink);padding:6px 12px;font-family:var(--mono);font-size:11px;letter-spacing:.08em;text-transform:uppercase}
    .rig .photo-frame .fig{position:absolute;top:16px;right:16px;background:var(--yellow);color:var(--ink);padding:6px 12px;font-family:var(--mono);font-size:11px;letter-spacing:.08em;text-transform:uppercase}

    .rig .grid-below{display:grid;grid-template-columns:1fr 1fr 1fr;gap:0;max-width:1100px;margin:48px auto 0;padding:0 32px}
    .rig .spec{padding:20px 24px 20px 0;border-right:1.5px solid rgba(246,241,231,.3);display:flex;flex-direction:column;gap:6px}
    .rig .spec:last-child{border-right:none;padding-right:0}
    .rig .spec .lbl{font-family:var(--mono);font-size:11px;letter-spacing:.08em;text-transform:uppercase;opacity:.7}
    .rig .spec .val{font-family:var(--narrow);font-weight:700;font-size:40px;line-height:1;letter-spacing:-.02em;text-transform:uppercase}
    .rig .spec .note{font-size:13px;line-height:1.45;opacity:.85}
    .rig-diagram-wrap{max-width:1100px;margin:48px auto 0;padding:0 32px}
    .rig-diagram-inner{background:white;padding:32px;border:2.5px solid var(--ink)}
    .rig-diagram-img{width:100%;height:auto;display:block}

    /* Personas */
    .personas{background:var(--cream);padding:120px 0;border-bottom:2.5px solid var(--ink)}
    .personas .intro{display:grid;grid-template-columns:1.2fr 1fr;gap:56px;align-items:end;margin:56px 0 56px}
    .personas .intro p{font-size:var(--t-lede);line-height:1.5;margin:0;max-width:460px;font-weight:500}

    .ptbl{width:100%;border-top:2px solid var(--ink);border-bottom:2px solid var(--ink);border-collapse:collapse}
    .ptbl thead th{padding:14px 16px;text-align:left;border-bottom:2px solid var(--ink);font-family:var(--mono);font-size:11px;letter-spacing:.08em;text-transform:uppercase;font-weight:500;opacity:.6;background:var(--yellow)}
    .ptbl tbody td{padding:22px 16px;border-bottom:1.5px solid rgba(11,15,26,.12);vertical-align:top;font-size:15px;line-height:1.45}
    .ptbl tbody tr:last-child td{border-bottom:none}
    .ptbl tbody td:first-child{width:18%}
    .ptbl .pname{display:flex;align-items:center;gap:12px}
    .ptbl .pname .dot{width:14px;height:14px;border-radius:50%;flex-shrink:0}
    .ptbl .pname b{font-family:var(--narrow);font-weight:700;font-size:22px;text-transform:uppercase;letter-spacing:-.01em;line-height:1}
    .ptbl .pname small{display:block;font-family:var(--mono);font-size:11px;letter-spacing:.08em;text-transform:uppercase;opacity:.55;margin-top:4px}
    .ptbl .quote{font-style:italic;font-family:var(--narrow);font-weight:500;font-size:17px;line-height:1.3}
    .ptbl .rec{font-family:var(--mono);font-size:12px;letter-spacing:.04em;background:var(--ink);color:var(--yellow);padding:4px 8px;display:inline-block}
    .ptbl .rec-link{text-decoration:none}.ptbl .rec-link:hover .rec{opacity:.8}

    /* Price */
    .price{background:var(--ink);color:var(--cream);padding:120px 0;border-bottom:2.5px solid var(--ink)}
    .price .sh{border-color:var(--cream);color:var(--cream)}
    .price .big{color:var(--cream)}
    .price .big em{color:var(--c1-size)}
    .price .intro{font-size:var(--t-lede);line-height:1.5;margin:2em 0 56px;max-width:640px;opacity:.85}
    .pgrid{display:grid;grid-template-columns:repeat(3,1fr);gap:0;border:2.5px solid var(--cream)}
    .pcard{padding:32px 28px;border-right:2.5px solid var(--cream);display:flex;flex-direction:column;gap:16px;background:var(--ink);transition:background .15s}
    .pcard:last-child{border-right:none}
    .pcard:hover{background:var(--ink-2)}
    .pcard .tag{display:flex;justify-content:space-between;align-items:center}
    .pcard .tag .name{font-family:var(--narrow);font-weight:700;font-size:22px;text-transform:uppercase;letter-spacing:-.01em}
    .pcard .tag .chip{font-family:var(--mono);font-size:10px;letter-spacing:.08em;text-transform:uppercase;padding:3px 8px;background:var(--c1-size);color:var(--ink)}
    .pcard.rec .tag .chip{background:var(--c5-permits);color:var(--cream)}
    .pcard .num{font-family:var(--narrow);font-weight:700;font-size:80px;line-height:.85;letter-spacing:-.03em}
    .pcard .num small{font-family:var(--mono);font-size:13px;letter-spacing:.04em;font-weight:500;opacity:.7;display:block;margin-top:1em;text-transform:uppercase}
    .pcard ul{list-style:none;padding:0;margin:0;font-size:14.5px;line-height:1.55}
    .pcard ul li{padding:8px 0;border-bottom:1px solid rgba(246,241,231,.2);display:flex;align-items:flex-start;gap:10px}
    .pcard ul li:last-child{border-bottom:none}
    .pcard ul li::before{content:"→";color:var(--c1-size);flex-shrink:0;font-family:var(--mono);font-weight:700}
    .pcard.rec{background:var(--ink-2);outline:2.5px solid var(--c5-permits);outline-offset:-2.5px;position:relative}
    .pcard-cta{margin-top:auto;display:flex;justify-content:space-between;align-items:center;padding:12px 16px;background:var(--cream);color:var(--ink);font-family:var(--mono);font-size:11px;font-weight:700;letter-spacing:.06em;text-transform:uppercase;text-decoration:none;transition:background .15s,color .15s}
    .pcard-cta:hover{background:var(--yellow)}
    .pcard.rec .pcard-cta{background:var(--c5-permits);color:var(--cream)}
    .pcard.rec .pcard-cta:hover{background:var(--yellow);color:var(--ink)}

    /* FAQ */
    .faq{background:var(--c5-permits);color:var(--cream);padding:120px 0;border-bottom:2.5px solid var(--ink)}
    .faq .sh{border-color:var(--cream);color:var(--cream)}
    .faq .big{color:var(--cream);margin-bottom:48px}
    .faq .big em{color:var(--ink);font-style:italic}
    .faq-list{border-top:2px solid var(--cream)}
    .faq-item{border-bottom:2px solid var(--cream);padding:32px 0;display:grid;grid-template-columns:60px 1fr;row-gap:16px;column-gap:32px;align-items:start}
    .faq-item .n{font-family:var(--mono);font-size:12px;letter-spacing:.08em;text-transform:uppercase;opacity:.85;padding-top:8px}
    .faq-item .q{font-family:var(--narrow);font-weight:700;font-size:clamp(26px,3.2vw,44px);line-height:1;letter-spacing:-.015em;text-transform:uppercase;margin:0;grid-column:2}
    .faq-item .a{font-size:18px;line-height:1.5;opacity:.9;grid-column:2;margin:0;max-width:760px;font-weight:500}

    /* CTA */
    .cta{background:var(--yellow);color:var(--ink);padding:140px 0 120px;border-bottom:2.5px solid var(--ink);position:relative;overflow:hidden}
    .cta .inner{max-width:1200px;margin:0 auto;padding:0 32px;text-align:center;position:relative;z-index:1}
    .cta .big{font-size:clamp(60px,11vw,180px);line-height:.84;margin-bottom:32px}
    .cta .big em{color:var(--c2-cond)}
    .cta p{font-size:22px;line-height:1.4;max-width:640px;margin:0 auto 40px;font-weight:500}
    .cta .btn{padding:22px 32px;font-size:18px}
    .cta .reassure{margin-top:40px;display:flex;gap:36px;justify-content:center;flex-wrap:wrap;font-family:var(--mono);font-size:11px;letter-spacing:.08em;text-transform:uppercase;opacity:.65}
    .cta .reassure span::before{content:"●";margin-right:8px;color:var(--c4-cost)}

    @media (max-width:960px){
      .hero-grid{grid-template-areas:"one" "two" "three" "four" "five";grid-template-columns:1fr}
      .problem .row,.five .intro,.personas .intro{grid-template-columns:1fr;gap:32px}
      .grid5{grid-template-columns:1fr 1fr}
      .blk{min-height:380px;border-right:2px solid var(--ink);border-bottom:2px solid var(--ink)}
      .blk:nth-child(2n){border-right:none}
      .blk:last-child{grid-column:1 / -1;border-bottom:none;border-right:none;min-height:240px}
      .rig .grid-below,.pgrid{grid-template-columns:1fr}
      .pcard{border-right:none;border-bottom:2.5px solid var(--cream)}
      .pcard:last-child{border-bottom:none}
      .faq-item{grid-template-columns:1fr;gap:12px}
      .faq-item .q, .faq-item .a{grid-column:1}
      .ptbl thead{display:none}
      .ptbl,.ptbl tbody,.ptbl tr,.ptbl td{display:block;width:100%}
      .ptbl tbody tr{border-bottom:2px solid var(--ink);padding:16px 0}
      .ptbl tbody td{border-bottom:none;padding:6px 0}
      .ptbl tbody td:first-child{width:auto}
    }

    @media (max-width:720px){
      .billboard{line-height:.92}
      .grid5{grid-template-columns:1fr}
      .blk{border-right:none!important;min-height:auto;padding:24px 20px 28px}
      .blk:last-child{min-height:auto}
      .big{font-size:clamp(36px,9vw,64px)}
      .cta .big{font-size:clamp(44px,12vw,80px)}
      .sh{grid-template-columns:auto 1fr;row-gap:6px}
      .sh .tg{grid-column:1 / -1;text-align:left;opacity:.5}
      .rig .wordmark{white-space:normal;line-height:.95;font-size:clamp(44px,13vw,72px)}
      .rig-inner{margin-top:24px}
      .rig .photo,.rig .grid-below{padding:0 20px}
    }
  </style>
</BaseLayout>