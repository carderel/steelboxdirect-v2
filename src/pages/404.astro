---
import BaseLayout from '../layouts/BaseLayout.astro';
export const prerender = true;
---

<BaseLayout
  title="Page Not Found (404) | Steel Box Direct"
  description="The page you're looking for doesn't exist or has moved. Browse containers, service areas, or request a quote."
  pageType="legal"
  noindex={true}
>
  <section class="nf">
    <div class="wrap">
      <span class="nf-code">404</span>
      <h1 class="nf-h1">This page took a wrong turn.</h1>
      <p class="nf-lede">The page you're looking for doesn't exist or has moved. Here's where most people are headed:</p>
      <div class="nf-links">
        <a href="/" class="btn">Back home →</a>
        <a href="/shipping-containers-for-sale/" class="btn-ghost">Browse containers</a>
        <a href="/locations/" class="btn-ghost">Service areas</a>
        <a href="/quote/" class="btn-ghost">Get a quote</a>
      </div>
    </div>
  </section>

  <style>
    .nf { background: var(--cream); padding: 120px 0; border-bottom: 2.5px solid var(--ink); min-height: 60vh; display: flex; align-items: center; }
    .nf-code { font-family: var(--narrow); font-weight: 700; font-size: clamp(80px, 16vw, 180px); line-height: .8; color: var(--c2-cond); display: block; letter-spacing: -.03em; }
    .nf-h1 { font-family: var(--narrow); font-weight: 700; font-size: clamp(32px, 5vw, 56px); text-transform: uppercase; line-height: 1; margin: 16px 0 0; letter-spacing: -.01em; }
    .nf-lede { font-size: 18px; line-height: 1.5; max-width: 560px; margin: 20px 0 36px; opacity: .8; }
    .nf-links { display: flex; gap: 16px; flex-wrap: wrap; align-items: center; }
  </style>
</BaseLayout>
